{
  "name": "shatter-vs",
  "displayName": "Shatter",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.81.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript"
  ],
  "main": "./dist/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.shatterAutotestFromEditorContextMenu",
        "title": "Autotest"
      },
      {
        "command": "extension.shatterRetestFromEditorContextMenu",
        "title": "Regression test"
      },
      {
        "command": "extension.shatterAutotestFromFunctionViewContainer",
        "title": "Autotest"
      },
      {
        "command": "extension.shatterRetestFromFunctionViewContainer",
        "title": "Regression test"
      },
      {
        "command": "extension.shatterResetLocalFromFunctionViewContainer",
        "title": "Reset Shatter workspace"
      },
      {
        "command": "extension.shatterReviewTestcasesFromTreeView",
        "title": "Reset Shatter workspace",
        "icon": {
          "dark": "resources/dark/open-preview.svg",
          "light": "resources/light/open-preview.svg"
        }
      },
      {
        "command": "extension.shatterMakeTestcasePersistent",
        "title": "Retain test case (view)",
        "icon": {
          "dark": "resources/dark/pin.svg",
          "light": "resources/light/pin.svg"
        }
      },
      {
        "command": "extension.shatterMakeTestcaseNonPersistent",
        "title": "Don't retain test case (view)",
        "icon": {
          "dark": "resources/dark/unpin.svg",
          "light": "resources/light/unpin.svg"
        }
      },
      {
        "command": "extension.shatterForkAutoTestcase",
        "title": "Fork test case",
        "icon": {
          "dark": "resources/dark/fork.svg",
          "light": "resources/light/fork.svg"
        }
      },
      {
        "command": "extension.shatterEditCustomTestcase",
        "title": "Edit test case",
        "icon": {
          "dark": "resources/dark/edit.svg",
          "light": "resources/light/edit.svg"
        }
      },
      {
        "command": "extension.shatterPersistTestcaseCluster",
        "title": "Run test cases",
        "icon": {
          "dark": "resources/dark/unpin.svg",
          "light": "resources/light/unpin.svg"
        }
      },
      {
        "command": "extension.shatterUnpersistTestcaseCluster",
        "title": "Run test cases",
        "icon": {
          "dark": "resources/dark/pin.svg",
          "light": "resources/light/pin.svg"
        }
      },
      {
        "command": "extension.shatterRunClustersTestcases",
        "title": "Run test cases",
        "icon": {
          "dark": "resources/dark/run-all.svg",
          "light": "resources/light/run-all.svg"
        }
      },
      {
        "command": "extension.shatterRunFunctionTestcases",
        "title": "Run test cases",
        "icon": {
          "dark": "resources/dark/run-all.svg",
          "light": "resources/light/run-all.svg"
        }
      },
      {
        "command": "extension.shatterRunTestcase",
        "title": "Run test case",
        "icon": {
          "dark": "resources/dark/play.svg",
          "light": "resources/light/play.svg"
        }
      },
      {
        "command": "extension.shatterAddTestcase",
        "title": "Add test case",
        "icon": {
          "dark": "resources/dark/add.svg",
          "light": "resources/light/add.svg"
        }
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "shatter.submenu",
          "group": "test-analyze"
        }
      ],
      "shatter.submenu": [
        {
          "command": "extension.shatterAutotestFromEditorContextMenu"
        },
        {
          "command": "extension.shatterRetestFromEditorContextMenu"
        }
      ],
      "view/item/context": [
        {
          "command": "extension.shatterAutotestFromFunctionViewContainer",
          "when": "view == shatter-functions-list",
          "group": "navigation@0"
        },
        {
          "command": "extension.shatterRetestFromFunctionViewContainer",
          "when": "view == shatter-functions-list",
          "group": "navigation@1"
        },
        {
          "command": "extension.shatterResetLocalFromFunctionViewContainer",
          "when": "view == shatter-functions-list",
          "group": "navigation@1"
        },
        {
          "command": "extension.shatterReviewTestcasesFromTreeView",
          "when": "view == shatter-list-testcases",
          "group": "inline"
        },
        {
          "command": "extension.shatterAddTestcase",
          "when": "view == shatter-list-testcases && false",
          "group": "navigation@2"
        },
        {
          "command": "extension.shatterEditCustomTestcase",
          "when": "view == shatter-list-testcases && viewItem =~ /\bcustom\b/",
          "group": "navigation@3"
        },
        {
          "command": "extension.shatterForkAutoTestcase",
          "when": "view == shatter-list-testcases && viewItem =~ /\bautotest\b/",
          "group": "navigation@3"
        },
        {
          "command": "extension.shatterRunClustersTestcases",
          "when": "view == shatter-execution-paths",
          "group": "inline"
        },
        {
          "command": "extension.shatterPersistTestcaseCluster",
          "when": "view == shatter-execution-paths && false",
          "group": "inline"
        },
        {
          "command": "extension.shatterUnpersistTestcaseCluster",
          "when": "view == shatter-execution-paths && false",
          "group": "inline"
        },
        {
          "command": "extension.shatterRunFunctionTestcases",
          "when": "(view == shatter-functions-list && viewItem =~ /\\bfunction\\b/)",
          "group": "inline"
        },
        {
          "command": "extension.shatterRunTestcase",
          "when": "(view == shatter-list-testcases) || (view == shatter-functions-list && viewItem =~ /\\btestcase\\b/)",
          "group": "inline@1"
        },
        {
          "command": "extension.shatterAddTestcase",
          "when": "view == shatter-functions-list && viewItem =~ /\\bfunction\\b/",
          "group": "inline@2"
        },
        {
          "command": "extension.shatterEditCustomTestcase",
          "when": "(view == shatter-list-testcases || view == shatter-functions-list) && viewItem =~ /\\btestcase\\b/",
          "group": "inline@3"
        },
        {
          "command": "extension.shatterForkAutoTestcase",
          "when": "view == shatter-list-testcases && viewItem =~ /\\bautotest\\b/",
          "group": "inline@4"
        },
        {
          "command": "extension.shatterMakeTestcasePersistent",
          "when": "view == shatter-list-testcases && !(viewItem =~ /\\bpersistent\\b/)",
          "group": "inline@5"
        },
        {
          "command": "extension.shatterMakeTestcaseNonPersistent",
          "when": "view == shatter-list-testcases && viewItem =~ /\\bpersistent\\b/",
          "group": "inline@6"
        }
      ]
    },
    "submenus": [
      {
        "id": "shatter.submenu",
        "label": "Shatter"
      }
    ],
    "configuration": [
      {
        "title": "Shatterproof",
        "properties": {
          "shatterproof.moduleDirectory": {
            "type": "string",
            "default": "",
            "description": "The directory where shatter modules are stored."
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shatter-detail-view",
          "title": "Shatter Details",
          "icon": "resources/hammer.svg"
        }
      ]
    },
    "views": {
      "shatter-detail-view": [
        {
          "id": "shatter-functions-list",
          "name": "Functions"
        },
        {
          "id": "shatter-execution-paths",
          "name": "Execution Paths"
        },
        {
          "id": "shatter-list-testcases",
          "name": "Test Cases"
        },
        {
          "id": "shatter-testcase-detail",
          "name": "Test Case Details"
        }
      ]
    }
  },
  "capabilities": {
    "virtualWorkspaces": {
      "supported": false,
      "description": "VSCode's FS APIs are too limited for Shatterproof to easily support virtual workspaces"
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/core": "^7.22.17",
    "@babel/plugin-proposal-decorators": "^7.23.0",
    "@babel/preset-env": "^7.22.15",
    "@babel/preset-typescript": "^7.22.15",
    "@types/jest": "^29.5.4",
    "@types/lodash": "^4.14.198",
    "@types/node": "16.x",
    "@types/vscode": "^1.82.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vscode/test-electron": "^2.3.4",
    "babel-jest": "^29.6.4",
    "eslint": "^8.47.0",
    "glob": "^10.3.3",
    "jest": "^29.6.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@faker-js/faker": "^8.0.2",
    "@paralleldrive/cuid2": "^2.2.2",
    "@types/serialize-javascript": "^5.0.2",
    "deep-object-diff": "^1.1.9",
    "fastest-levenshtein": "^1.0.16",
    "lodash": "^4.17.21",
    "serialize-javascript": "^6.0.1",
    "source-map": "^0.7.4"
  }
}