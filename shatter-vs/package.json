{
  "name": "shatter-vs",
  "displayName": "Shatter",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.81.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript"
  ],
  "main": "./out/extension/index.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.shatterAutotestContext",
        "title": "Autotest"
      },
      {
        "command": "extension.shatterRetestContext",
        "title": "Regression test"
      },
      {
        "command": "extension.shatterAutotestFunctionViewContainer",
        "title": "Autotest"
      },
      {
        "command": "extension.shatterRetestFunctionViewContainer",
        "title": "Regression test"
      },
      {
        "command": "extension.shatterAddTestcaseViewContainer",
        "title": "Add test case (view)",
        "icon": "resources/add.svg"
      },
      {
        "command": "extension.shatterMakeTestcaseNonPersistentViewContainer",
        "title": "Don't retain test case (view)",
        "icon": "resources/unpin.svg"
      },
      {
        "command": "extension.shatterMakeTestcasePersistentViewContainer",
        "title": "Retain test case (view)",
        "icon": "resources/pin.svg"
      },
      {
        "command": "extension.shatterEditTestcaseViewContainer",
        "title": "Edit test case (view)",
        "icon": "resources/edit.svg"
      },
      {
        "command": "extension.shatterEditTestcaseContext",
        "title": "Edit test case"
      },
      {
        "command": "extension.shatterAddTestcaseContext",
        "title": "Add test case"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "shatter.submenu",
          "group": "test-analyze"
        }
      ],
      "shatter.submenu": [
        {
          "command": "extension.shatterAutotestContext"
        },
        {
          "command": "extension.shatterRetestContext"
        },
        {
          "command": "extension.shatterAddTestcaseContext"
        }
      ],
      "view/item/context": [
        {
          "command": "extension.shatterAutotestFunctionViewContainer",
          "when": "view == shatter-functions-list",
          "group": "navigation@0"
        },
        {
          "command": "extension.shatterRetestFunctionViewContainer",
          "when": "view == shatter-functions-list",
          "group": "navigation@1"
        },
        {
          "command": "extension.shatterAddTestcaseViewContainer",
          "when": "view == shatter-list-testcases",
          "group": "navigation@2"
        },
        {
          "command": "extension.shatterEditTestcaseViewContainer",
          "when": "view == shatter-list-testcases",
          "group": "navigation@3"
        },
        {
          "command": "extension.shatterAddTestcaseViewContainer",
          "when": "view == shatter-list-testcases",
          "group": "inline"
        },
        {
          "command": "extension.shatterEditTestcaseViewContainer",
          "when": "view == shatter-list-testcases",
          "group": "inline"
        },
        {
          "command": "extension.shatterMakeTestcaseNonPersistentViewContainer",
          "when": "view == shatter-list-testcases && extension.selectedTestcaseIsPersistent",
          "group": "inline"
        },
        {
          "command": "extension.shatterMakeTestcasePersistentViewContainer",
          "when": "view == shatter-list-testcases && !extension.selectedTestcaseIsPersistent",
          "group": "inline"
        }
      ]
    },
    "submenus": [
      {
        "id": "shatter.submenu",
        "label": "Shatter"
      }
    ],
    "configuration": [
      {
        "title": "Shatterproof",
        "properties": {
          "shatterproof.moduleDirectory": {
            "type": "string",
            "default": "",
            "description": "The directory where shatter modules are stored."
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shatter-detail-view",
          "title": "Shatter Details",
          "icon": "resources/hammer.svg"
        }
      ]
    },
    "views": {
      "shatter-detail-view": [
        {
          "id": "shatter-functions-list",
          "name": "Functions"
        },
        {
          "id": "shatter-execution-paths",
          "name": "Execution Paths"
        },
        {
          "id": "shatter-list-testcases",
          "name": "Test Cases"
        },
        {
          "id": "shatter-testcase-detail",
          "name": "Test Case Details"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "jest"
  },
  "devDependencies": {
    "@babel/core": "^7.22.17",
    "@babel/plugin-proposal-decorators": "^7.23.0",
    "@babel/preset-env": "^7.22.15",
    "@babel/preset-typescript": "^7.22.15",
    "@types/jest": "^29.5.4",
    "@types/lodash": "^4.14.198",
    "@types/node": "16.x",
    "@types/vscode": "^1.82.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vscode/test-electron": "^2.3.4",
    "babel-jest": "^29.6.4",
    "eslint": "^8.47.0",
    "glob": "^10.3.3",
    "jest": "^29.6.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@faker-js/faker": "^8.0.2",
    "@paralleldrive/cuid2": "^2.2.2",
    "@types/serialize-javascript": "^5.0.2",
    "deep-object-diff": "^1.1.9",
    "fastest-levenshtein": "^1.0.16",
    "lodash": "^4.17.21",
    "serialize-javascript": "^6.0.1",
    "source-map": "^0.7.4"
  }
}