{
  "name": "shatter-vs",
  "displayName": "Shatter",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.81.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.shatterAutotestContext",
        "title": "Shatter autotest"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "extension.shatterAutotestContext",
          "group": "test-analyze"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "shatterResultsView",
          "name": "Shatter Results"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.82.0",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vscode/test-electron": "^2.3.4",
    "eslint": "^8.47.0",
    "glob": "^10.3.3",
    "mocha": "^10.2.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@faker-js/faker": "^8.0.2",
    "@paralleldrive/cuid2": "^2.2.2"
  }
}
