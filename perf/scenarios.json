{
  "version": 1,
  "defaults": {
    "workdir": ".",
    "warmups": 1,
    "iterations": 5,
    "timeout_seconds": 300,
    "timing_target": "none",
    "env": {
      "CARGO_NET_OFFLINE": "true"
    }
  },
  "isolation_corpus_note": "isolation_mode fields are placeholders (str-19pm.8). The runner does not yet inject --isolation into commands — that support lands in str-19pm.9. Until then all three mode variants of each scenario run identically, establishing the baseline timing matrix for later comparison. See perf/isolation-corpus.md for the full corpus rationale.",
  "scenarios": [
    {
      "id": "gauntlet-auto-cold",
      "kind": "gauntlet",
      "description": "Full automated gauntlet with isolated cold caches.",
      "command": ["bash", "demo/gauntlet.sh", "--auto", "--delay", "0"],
      "timing_target": "gauntlet",
      "cache_mode": "cold",
      "warmups": 0,
      "iterations": 3,
      "timeout_seconds": 900,
      "profilers": ["perf-stat", "perf-record"]
    },
    {
      "id": "gauntlet-auto-warm",
      "kind": "gauntlet",
      "description": "Repeat gauntlet after the harness has populated build and cache state.",
      "command": ["bash", "demo/gauntlet.sh", "--auto", "--delay", "0"],
      "timing_target": "gauntlet",
      "cache_mode": "warm",
      "iterations": 3,
      "timeout_seconds": 900,
      "profilers": ["perf-stat"]
    },
    {
      "id": "explore-ts-arithmetic-cold",
      "kind": "command",
      "description": "Representative TypeScript explore path from the gauntlet.",
      "command": [
        "target/debug/shatter",
        "explore",
        "examples/standalone/ts/01-arithmetic.ts:classifyNumber"
      ],
      "language": "typescript",
      "sample_ref": "walkthrough.typescript[0]",
      "timing_target": "shatter",
      "cache_mode": "cold",
      "iterations": 5,
      "timeout_seconds": 180,
      "profilers": ["perf-stat", "perf-record"]
    },
    {
      "id": "explore-ts-arithmetic-warm",
      "kind": "command",
      "description": "Repeated TypeScript explore run to measure cache and startup reuse.",
      "command": [
        "target/debug/shatter",
        "explore",
        "examples/standalone/ts/01-arithmetic.ts:classifyNumber"
      ],
      "language": "typescript",
      "sample_ref": "walkthrough.typescript[0]",
      "timing_target": "shatter",
      "cache_mode": "warm",
      "iterations": 5,
      "timeout_seconds": 180,
      "profilers": ["perf-stat"]
    },
    {
      "id": "explore-go-language-cold",
      "kind": "command",
      "description": "Representative Go explore path from the gauntlet.",
      "command": [
        "target/debug/shatter",
        "explore",
        "--max-iterations",
        "3",
        "--timeout-explore",
        "25",
        "examples/standalone/go/18-accept-language.go:NegotiateLanguage"
      ],
      "language": "go",
      "sample_ref": "walkthrough.go[3]",
      "timing_target": "shatter",
      "cache_mode": "cold",
      "iterations": 5,
      "timeout_seconds": 240,
      "profilers": ["perf-stat", "perf-record"]
    },
    {
      "id": "explore-rust-language-cold",
      "kind": "command",
      "description": "Representative Rust frontend explore path from the gauntlet.",
      "command": [
        "target/debug/shatter",
        "explore",
        "--max-iterations",
        "3",
        "--timeout-explore",
        "25",
        "examples/standalone/rust/18_accept_language.rs:negotiate_language"
      ],
      "language": "rust",
      "sample_ref": "walkthrough.rust[3]",
      "timing_target": "shatter",
      "cache_mode": "cold",
      "iterations": 5,
      "timeout_seconds": 240,
      "profilers": ["perf-stat", "perf-record"]
    },
    {
      "id": "scan-standalone-ts-cold",
      "kind": "command",
      "description": "Directory scan over standalone TypeScript examples.",
      "command": [
        "target/debug/shatter",
        "scan",
        "--parallelism",
        "2",
        "--timeout-per-fn",
        "30",
        "examples/standalone/ts"
      ],
      "language": "typescript",
      "timing_target": "shatter",
      "cache_mode": "cold",
      "iterations": 3,
      "timeout_seconds": 420,
      "profilers": ["perf-stat", "perf-record"]
    },
    {
      "id": "scan-standalone-ts-warm",
      "kind": "command",
      "description": "Repeat TypeScript scan with warm cache state.",
      "command": [
        "target/debug/shatter",
        "scan",
        "--parallelism",
        "2",
        "--timeout-per-fn",
        "30",
        "examples/standalone/ts"
      ],
      "language": "typescript",
      "timing_target": "shatter",
      "cache_mode": "warm",
      "iterations": 3,
      "timeout_seconds": 420,
      "profilers": ["perf-stat"]
    },
    {
      "id": "go-frontend-instrument-tests",
      "kind": "go_test",
      "description": "Go-isolated frontend package tests suitable for pprof follow-up without source changes.",
      "command": [
        "go",
        "test",
        "./shatter-go/instrument",
        "-run",
        "TestExecutor",
        "-count=1"
      ],
      "workdir": ".",
      "cache_mode": "warm",
      "warmups": 0,
      "iterations": 3,
      "timeout_seconds": 180,
      "profilers": ["perf-stat", "pprof"]
    },

    {
      "id": "isolation-explore-ts-simple-none",
