func TestTranscribeWorkerWork_NilDeps(t *testing.T) {
	w := &TranscribeWorker{}
	job := &river.Job[TranscribeArgs]{
		Args: TranscribeArgs{ItemID: uuid.New(), OwnerID: uuid.New(), AudioKey: "user/uploads/audio.wav"},
	}
	err := w.Work(context.Background(), job)
	if err == nil {
		t.Error("expected error for nil storage, got nil")
	}
}

func TestEmbedWorkerWork(t *testing.T) {
	w := &EmbedWorker{}
	job := &river.Job[EmbedArgs]{
		Args: EmbedArgs{ItemID: uuid.New(), Content: "test content"},
	}
	if err := w.Work(context.Background(), job); err != nil {
		t.Errorf("EmbedWorker.Work() returned error: %v", err)
	}
}

