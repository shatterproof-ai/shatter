func TestArgsExtraMounts(t *testing.T) {
	cfg := baseConfig()
	cfg.ExtraRO = []string{"/opt/tools", "/usr/share/data"}
	cfg.ExtraRW = []string{"/var/cache/builds"}
	args := cfg.Args()

	for _, p := range cfg.ExtraRO {
		if findTriple(args, "--ro-bind", p, p) < 0 {
			t.Errorf("extra RO mount %s not found", p)
		}
	}
	for _, p := range cfg.ExtraRW {
		if findTriple(args, "--bind", p, p) < 0 {
			t.Errorf("extra RW mount %s not found", p)
		}
	}

	// Extra mounts should come before --chdir
	chdirIdx := findPair(args, "--chdir", cfg.WorkDir)
	for _, p := range cfg.ExtraRO {
		if idx := findTriple(args, "--ro-bind", p, p); idx > chdirIdx {
			t.Errorf("extra RO mount %s should come before --chdir", p)
		}
	}
}

// TestArgsEmptyHome documents that path.Join("", ".claude") produces ".claude"
// (a relative path), which is a bug. This test locks in the current behavior.
func TestArgsEmptyHome(t *testing.T) {
	cfg := baseConfig()
	cfg.Home = ""
	args := cfg.Args()

	// path.Join("", ".claude") => ".claude" (relative, not absolute)
	if findTriple(args, "--bind", cfg.ClaudeHome, ".claude") < 0 {
		t.Error("expected .claude as mount target when Home is empty (documents bug)")
	}

	// --tmpfs "" is also produced
	if findPair(args, "--tmpfs", "") < 0 {
		t.Error("expected --tmpfs with empty string when Home is empty")
	}
}

// TestArgsEmptyRequiredFields documents that a zero-value SandboxConfig
// doesn't panic and produces args with empty strings throughout.
func TestArgsEmptyRequiredFields(t *testing.T) {
	cfg := SandboxConfig{}
	args := cfg.Args()

	if args == nil {
		t.Fatal("Args() returned nil for zero-value config")
	}
	if len(args) == 0 {
		t.Fatal("Args() returned empty slice for zero-value config")
	}

	// Should still have the structural flags
	if findPair(args, "--ro-bind", "/") < 0 {
		t.Error("missing --ro-bind / even with zero-value config")
	}
	if findPair(args, "--proc", "/proc") < 0 {
		t.Error("missing --proc /proc even with zero-value config")
	}
}

// TestArgsPathsWithSpaces verifies that paths with spaces remain as separate
// slice elements, which is correct for exec.Command (no shell quoting needed).
func TestArgsPathsWithSpaces(t *testing.T) {
	cfg := baseConfig()
	cfg.AgentRepo = "/home/my user/repo"
	cfg.WorkDir = "/home/my user/repo"
	args := cfg.Args()

	// The path must appear as a single element, not split on spaces
	if findTriple(args, "--bind", "/home/my user/repo", "/home/my user/repo") < 0 {
		t.Error("path with spaces should be a single slice element")
	}
	if findPair(args, "--chdir", "/home/my user/repo") < 0 {
		t.Error("--chdir path with spaces should be a single slice element")
	}
}

// TestArgsRelativePaths documents that relative paths pass through unchanged.
// It is the caller's responsibility to provide absolute paths.
func TestArgsRelativePaths(t *testing.T) {
	cfg := baseConfig()
	cfg.AgentRepo = "agents/fix-auth/repo"
	cfg.WorkDir = "agents/fix-auth/repo"
	args := cfg.Args()

	if findTriple(args, "--bind", "agents/fix-auth/repo", "agents/fix-auth/repo") < 0 {
		t.Error("relative path should pass through unchanged in AgentRepo bind")
	}
	if findPair(args, "--chdir", "agents/fix-auth/repo") < 0 {
		t.Error("relative path should pass through unchanged in --chdir")
	}
}

// TestArgsEmptyExtraMounts documents that an empty string in ExtraRO
// produces --ro-bind "" "" in the args (caller's responsibility to validate).
func TestArgsEmptyExtraMounts(t *testing.T) {
	cfg := baseConfig()
	cfg.ExtraRO = []string{""}
	args := cfg.Args()

	if findTriple(args, "--ro-bind", "", "") < 0 {
		t.Error("empty string in ExtraRO should produce --ro-bind with empty strings")
	}
}

func TestValidate(t *testing.T) {
	t.Run("valid config", func(t *testing.T) {
		cfg := baseConfig()
		if err := cfg.Validate(); err != nil {
			t.Errorf("Validate() unexpected error: %v", err)
		}
	})

	t.Run("empty Home", func(t *testing.T) {
		cfg := baseConfig()
		cfg.Home = ""
		if err := cfg.Validate(); err == nil {
			t.Error("Validate() expected error for empty Home")
		}
	})

	t.Run("relative Home", func(t *testing.T) {
		cfg := baseConfig()
		cfg.Home = "relative/path"
		if err := cfg.Validate(); err == nil {
			t.Error("Validate() expected error for relative Home")
		}
	})

	t.Run("empty AgentRepo", func(t *testing.T) {
		cfg := baseConfig()
		cfg.AgentRepo = ""
		if err := cfg.Validate(); err == nil {
			t.Error("Validate() expected error for empty AgentRepo")
		}
	})

	t.Run("zero-value config", func(t *testing.T) {
		cfg := SandboxConfig{}
		if err := cfg.Validate(); err == nil {
			t.Error("Validate() expected error for zero-value config")
		}
	})
}
