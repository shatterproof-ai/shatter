package sandbox

import (
	"slices"
	"testing"
)

func baseConfig() SandboxConfig {
	return SandboxConfig{
		AgentRepo:    "/workspace/agents/fix-auth/repo",
		TeamMailbox:  "/home/user/.claude/teams/myteam",
		ClaudeHome:   "/workspace/agents/fix-auth/claude-home",
		ClaudeBinDir: "/home/user/.local/share/claude/versions",
		Home:         "/home/user",
		User:         "user",
		WorkDir:      "/workspace/agents/fix-auth/repo",
	}
}

// findPair returns the index of a flag-value pair in args, or -1.
func findPair(args []string, flag, value string) int {
	for i := 0; i < len(args)-1; i++ {
		if args[i] == flag && args[i+1] == value {
			return i
		}
	}
	return -1
}

// findTriple returns the index of a flag with two values in args, or -1.
func findTriple(args []string, flag, v1, v2 string) int {
	for i := 0; i < len(args)-2; i++ {
		if args[i] == flag && args[i+1] == v1 && args[i+2] == v2 {
			return i
		}
	}
	return -1
}

func TestArgsRequiredFlags(t *testing.T) {
	cfg := baseConfig()
	args := cfg.Args()

	checks := []struct {
		name string
		ok   bool
	}{
		{"ro-bind root", findPair(args, "--ro-bind", "/") >= 0},
		{"tmpfs home", findPair(args, "--tmpfs", "/home/user") >= 0},
		{"bind claude home", findTriple(args, "--bind", cfg.ClaudeHome, "/home/user/.claude") >= 0},
		{"bind agent repo", findTriple(args, "--bind", cfg.AgentRepo, cfg.AgentRepo) >= 0},
		{"bind team mailbox", findTriple(args, "--bind", cfg.TeamMailbox, cfg.TeamMailbox) >= 0},
		{"ro-bind claude bin", findTriple(args, "--ro-bind", cfg.ClaudeBinDir, cfg.ClaudeBinDir) >= 0},
		{"tmpfs /tmp", findPair(args, "--tmpfs", "/tmp") >= 0},
		{"proc /proc", findPair(args, "--proc", "/proc") >= 0},
		{"dev /dev", findPair(args, "--dev", "/dev") >= 0},
		{"setenv HOME", findTriple(args, "--setenv", "HOME", "/home/user") >= 0},
		{"setenv USER", findTriple(args, "--setenv", "USER", "user") >= 0},
		{"setenv SSH_AUTH_SOCK", findTriple(args, "--setenv", "SSH_AUTH_SOCK", "") >= 0},
		{"chdir", findPair(args, "--chdir", cfg.WorkDir) >= 0},
	}

	for _, c := range checks {
		if !c.ok {
			t.Errorf("missing required flag: %s", c.name)
		}
	}
}

func TestArgsMountOrder(t *testing.T) {
	cfg := baseConfig()
	args := cfg.Args()

	roBindRoot := findPair(args, "--ro-bind", "/")
	tmpfsHome := findPair(args, "--tmpfs", "/home/user")
	bindClaude := findTriple(args, "--bind", cfg.ClaudeHome, "/home/user/.claude")

	if roBindRoot >= tmpfsHome {
		t.Error("--ro-bind / must come before --tmpfs $HOME")
	}
	if tmpfsHome >= bindClaude {
		t.Error("--tmpfs $HOME must come before --bind .claude")
	}
}

func TestArgsChdirIsLast(t *testing.T) {
	cfg := baseConfig()
	args := cfg.Args()

	idx := findPair(args, "--chdir", cfg.WorkDir)
	if idx < 0 {
		t.Fatal("--chdir not found")
	}
	if idx != len(args)-2 {
		t.Errorf("--chdir should be last flag pair, but found at index %d of %d", idx, len(args))
	}
}

func TestArgsOptionalClaudeJSON(t *testing.T) {
	t.Run("present", func(t *testing.T) {
		cfg := baseConfig()
		cfg.ClaudeJSON = "/home/user/.claude.json"
		args := cfg.Args()

		if findTriple(args, "--bind", "/home/user/.claude.json", "/home/user/.claude.json") < 0 {
			t.Error("--bind for .claude.json not found")
		}
	})

	t.Run("absent", func(t *testing.T) {
		cfg := baseConfig()
		args := cfg.Args()

		if slices.Contains(args, ".claude.json") {
			t.Error(".claude.json should not appear when ClaudeJSON is empty")
		}
	})
}

