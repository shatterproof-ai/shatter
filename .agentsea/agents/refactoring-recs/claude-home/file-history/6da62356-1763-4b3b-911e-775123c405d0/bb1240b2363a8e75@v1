func TestDetect(t *testing.T) {
	// Create a fake base dir with one workspace
	baseDir := t.TempDir()
	wsDir := filepath.Join(baseDir, "myproject")
	if err := os.MkdirAll(wsDir, 0755); err != nil {
		t.Fatal(err)
	}

	// Create a project directory to match against
	projectDir := t.TempDir()

	yaml := "repo_url: git@github.com:org/repo.git\nproject_path: " + projectDir + "\ndefault_branch: main\n"
	if err := os.WriteFile(filepath.Join(wsDir, "workspace.yaml"), []byte(yaml), 0644); err != nil {
		t.Fatal(err)
	}

	// Change to the project directory
	origDir, _ := os.Getwd()
	defer os.Chdir(origDir)
	os.Chdir(projectDir)

	ws, err := DetectWithBase(baseDir)
	if err != nil {
		t.Fatalf("DetectWithBase() error: %v", err)
	}
	if ws.Config.ProjectPath != projectDir {
		t.Errorf("ProjectPath = %q, want %q", ws.Config.ProjectPath, projectDir)
	}
}

