func TestDetect_MultipleMatches(t *testing.T) {
	// ReadDir returns entries sorted alphabetically, so "aaa" should win over "bbb".
	baseDir := t.TempDir()
	projectDir := t.TempDir()

	for _, name := range []string{"aaa", "bbb"} {
		wsDir := filepath.Join(baseDir, name)
		if err := os.MkdirAll(wsDir, 0755); err != nil {
			t.Fatal(err)
		}
		yamlContent := "repo_url: git@github.com:org/" + name + ".git\nproject_path: " + projectDir + "\ndefault_branch: main\n"
		if err := os.WriteFile(filepath.Join(wsDir, "workspace.yaml"), []byte(yamlContent), 0644); err != nil {
			t.Fatal(err)
		}
	}

	origDir, _ := os.Getwd()
	defer os.Chdir(origDir)
	os.Chdir(projectDir)

	ws, err := DetectWithBase(baseDir)
	if err != nil {
		t.Fatalf("DetectWithBase() error: %v", err)
	}
	// First alphabetical match ("aaa") should win
	if ws.Config.RepoURL != "git@github.com:org/aaa.git" {
		t.Errorf("expected first alphabetical match (aaa), got RepoURL=%q", ws.Config.RepoURL)
	}
}

