func TestDetect_RelativeProjectPath(t *testing.T) {
	projectDir := t.TempDir()
	// Workspace exists but has relative project_path — should still load since
	// DetectFrom walks up looking for .agentsea/workspace.yaml (it doesn't filter by project_path)
	yaml := "repo_url: git@github.com:org/repo.git\nproject_path: relative/path\ndefault_branch: main\n"
	setupProjectWithWorkspace(t, projectDir, yaml)

	ws, err := DetectFrom(projectDir)
	if err != nil {
		t.Fatalf("DetectFrom() unexpected error: %v", err)
	}
	if ws.Config.ProjectPath != "relative/path" {
		t.Errorf("ProjectPath = %q, want %q", ws.Config.ProjectPath, "relative/path")
	}
}

func TestLoad_AgentProfiles(t *testing.T) {
	dir := t.TempDir()
	yamlContent := `repo_url: git@github.com:org/repo.git
project_path: /home/user/project
default_branch: main
agent_profiles:
  default:
    model: claude-sonnet-4-6
    effort: low
  researcher:
    model: claude-opus-4-6
    effort: high
  coder:
    model: claude-sonnet-4-6
`
	if err := os.WriteFile(filepath.Join(dir, "workspace.yaml"), []byte(yamlContent), 0644); err != nil {
		t.Fatal(err)
	}

	ws, err := Load(dir)
	if err != nil {
		t.Fatalf("Load() error: %v", err)
	}

	if len(ws.Config.AgentProfiles) != 3 {
		t.Fatalf("AgentProfiles: got %d entries, want 3", len(ws.Config.AgentProfiles))
	}

	tests := []struct {
		name       string
		wantModel  string
		wantEffort string
	}{
		{"default", "claude-sonnet-4-6", "low"},
		{"researcher", "claude-opus-4-6", "high"},
		{"coder", "claude-sonnet-4-6", ""},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			p := ws.Config.AgentProfiles[tt.name]
			if p.Model != tt.wantModel {
				t.Errorf("Model = %q, want %q", p.Model, tt.wantModel)
			}
			if p.Effort != tt.wantEffort {
				t.Errorf("Effort = %q, want %q", p.Effort, tt.wantEffort)
			}
		})
	}
}

