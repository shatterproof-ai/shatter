// setupProjectWithWorkspace creates a project directory with .agentsea/workspace.yaml
// and returns the project root directory.
func setupProjectWithWorkspace(t *testing.T, projectDir string, yamlContent string) {
	t.Helper()
	wsDir := filepath.Join(projectDir, DirName)
	if err := os.MkdirAll(wsDir, 0755); err != nil {
		t.Fatal(err)
	}
	if err := os.WriteFile(filepath.Join(wsDir, "workspace.yaml"), []byte(yamlContent), 0644); err != nil {
		t.Fatal(err)
	}
}

func TestDetect(t *testing.T) {
	projectDir := t.TempDir()
	yaml := "repo_url: git@github.com:org/repo.git\nproject_path: " + projectDir + "\ndefault_branch: main\n"
	setupProjectWithWorkspace(t, projectDir, yaml)

	origDir, _ := os.Getwd()
	defer os.Chdir(origDir)
	os.Chdir(projectDir)

	ws, err := DetectFrom(projectDir)
	if err != nil {
		t.Fatalf("DetectFrom() error: %v", err)
	}
	if ws.Config.ProjectPath != projectDir {
		t.Errorf("ProjectPath = %q, want %q", ws.Config.ProjectPath, projectDir)
	}
}

