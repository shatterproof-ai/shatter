func TestLoad(t *testing.T) {
	dir := t.TempDir()
	yaml := `repo_url: git@github.com:org/repo.git
project_path: /home/user/project/myrepo
default_branch: main
extra_ro_mounts:
  - /home/user/.cargo
  - /home/user/.rustup
extra_rw_mounts:
  - /tmp/scratch
agent_env:
  DATABASE_URL: "postgres://localhost:5432/dev"
  FOO: bar
`
	if err := os.WriteFile(filepath.Join(dir, "workspace.yaml"), []byte(yaml), 0644); err != nil {
		t.Fatal(err)
	}

	ws, err := Load(dir)
	if err != nil {
		t.Fatalf("Load() error: %v", err)
	}

	tests := []struct {
		name string
		got  string
		want string
	}{
		{"RepoURL", ws.Config.RepoURL, "git@github.com:org/repo.git"},
		{"ProjectPath", ws.Config.ProjectPath, "/home/user/project/myrepo"},
		{"DefaultBranch", ws.Config.DefaultBranch, "main"},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			if tt.got != tt.want {
				t.Errorf("got %q, want %q", tt.got, tt.want)
			}
		})
	}

	if len(ws.Config.ExtraROMounts) != 2 {
		t.Errorf("ExtraROMounts: got %d items, want 2", len(ws.Config.ExtraROMounts))
	}
	if len(ws.Config.ExtraRWMounts) != 1 {
		t.Errorf("ExtraRWMounts: got %d items, want 1", len(ws.Config.ExtraRWMounts))
	}
	if ws.Config.AgentEnv["DATABASE_URL"] != "postgres://localhost:5432/dev" {
		t.Errorf("AgentEnv[DATABASE_URL] = %q", ws.Config.AgentEnv["DATABASE_URL"])
	}
	if ws.Config.AgentEnv["FOO"] != "bar" {
		t.Errorf("AgentEnv[FOO] = %q", ws.Config.AgentEnv["FOO"])
	}
}

