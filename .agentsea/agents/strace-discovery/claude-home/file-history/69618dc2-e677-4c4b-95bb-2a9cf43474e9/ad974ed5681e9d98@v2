FROM mcr.microsoft.com/devcontainers/go:1.24

# PostgreSQL 17 + PostGIS (runs inside the container — no compose needed)
# hadolint ignore=DL3008
RUN apt-get update && apt-get install -y --no-install-recommends \
    postgresql-17 postgresql-17-postgis-3 \
    xz-utils jq tmux \
    && rm -rf /var/lib/apt/lists/*

# Dolt (required for beads server mode — concurrent worktree access)
# hadolint ignore=DL4006
RUN curl -L https://github.com/dolthub/dolt/releases/latest/download/install.sh | bash

# Go dev tools (slow downloads, version-pinned)
RUN go install github.com/air-verse/air@v1.61.7 \
    && go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.1.6

# Claude Code CLI
# hadolint ignore=DL4006
RUN curl -fsSL https://claude.ai/install.sh | bash
