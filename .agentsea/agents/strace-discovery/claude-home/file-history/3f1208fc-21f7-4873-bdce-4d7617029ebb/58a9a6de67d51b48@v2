#!/bin/bash
set -euo pipefail

FROM=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --job)    JOB="$2"; shift 2 ;;
        --run)    RUN="$2"; shift 2 ;;
        --result) RESULT="$2"; shift 2 ;;
        --to)     TO="$2"; shift 2 ;;
        --from)   FROM="$2"; shift 2 ;;
        *)        echo "Unknown argument: $1" >&2; exit 1 ;;
    esac
done

SUBJECT="[Dropkick CI] $JOB #$RUN: $RESULT"
LINK="http://localhost:8080/jobs/$JOB/$RUN"

msmtp -t <<EOF
To: $TO
From: ${FROM:-ci@dropkick.local}
Subject: $SUBJECT

Job:    $JOB
Run:    #$RUN
Result: $RESULT

Details: $LINK
EOF
