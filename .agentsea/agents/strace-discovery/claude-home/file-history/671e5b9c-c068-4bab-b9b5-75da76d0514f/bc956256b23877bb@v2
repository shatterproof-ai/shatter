import { test, expect } from '@playwright/test'
import { searchWith, waitForResults } from './helpers'

// ── Critical ────────────────────────────────────────────────────────────────

test.describe('Authentication UI', () => {
  test('unauthenticated state shows Sign In button in header @critical @auth', async ({
    page,
  }) => {
    await page.goto('/')

    // Sign In button should be visible when not logged in
    await expect(
      page.getByRole('button', { name: 'Sign In' }),
    ).toBeVisible()
  })

  // ── Standard ──────────────────────────────────────────────────────────────

  test('sign-in dropdown shows Continue with Google option @standard @auth', async ({
    page,
  }) => {
    await page.goto('/')

    // Click the Sign In button to open the dropdown
    await page.getByRole('button', { name: 'Sign In' }).click()

    // Menu item "Continue with Google" should appear
    await expect(
      page.getByRole('menuitem', { name: /Continue with Google/i }),
    ).toBeVisible()
  })

  test.skip('signed-in state shows user menu with name and email @standard @auth', async ({
    // eslint-disable-next-line @typescript-eslint/no-unused-vars
    page,
  }) => {
    // TODO: Requires mock Supabase auth setup or test account.
    // Use Playwright route interception to mock auth responses when available.
  })
})

// ── Comprehensive ───────────────────────────────────────────────────────────

test.describe('Preferences', () => {
  test('location persists through URL params across page reload @comprehensive @auth', async ({
    page,
  }) => {
    // Set location via URL params (simulates a resolved ZIP code)
    await searchWith(page, {
      userLat: '42.33',
      userLng: '-71.11',
      userState: 'MA',
    })
    await waitForResults(page)

    // Verify location is displayed (Clear location button visible)
    await expect(page.getByLabel('Clear location')).toBeVisible({
      timeout: 10_000,
    })

    // Distance badges should be visible
    const distanceBadges = page.getByTestId('distance')
    await expect(distanceBadges.first()).toBeVisible({ timeout: 10_000 })

    // Copy the URL with location params
    const urlWithLocation = page.url()
    expect(urlWithLocation).toContain('userLat=')
    expect(urlWithLocation).toContain('userLng=')

    // Reload the page with the same URL
    await page.goto(urlWithLocation)
    await waitForResults(page)

    // Location should still be set after reload
    await expect(page.getByLabel('Clear location')).toBeVisible({
      timeout: 10_000,
    })

    // Distance badges should still be visible
    await expect(distanceBadges.first()).toBeVisible({ timeout: 10_000 })
  })
})
