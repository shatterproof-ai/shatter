package posthog

import (
	"log/slog"
	"os"
	"testing"
)

func TestNew_Disabled(t *testing.T) {
	c, err := New("", "")
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	if c.Enabled() {
		t.Fatal("expected client to be disabled when API key is empty")
	}
	if c.Inner() != nil {
		t.Fatal("expected Inner() to return nil when disabled")
	}
	// Close should be safe on disabled client
	if err := c.Close(); err != nil {
		t.Fatalf("unexpected error on Close: %v", err)
	}
}

func TestWrapSlogHandler_Disabled(t *testing.T) {
	c, err := New("", "")
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	base := slog.NewTextHandler(os.Stderr, nil)
	wrapped := c.WrapSlogHandler(base)
	// When disabled, should return the same handler
	if wrapped != base {
		t.Fatal("expected WrapSlogHandler to return base handler when disabled")
	}
}
