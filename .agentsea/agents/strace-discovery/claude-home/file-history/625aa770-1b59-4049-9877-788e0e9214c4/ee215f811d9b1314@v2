# Lefthook — git hook orchestration
# https://github.com/evilmartians/lefthook
#
# Install:   go install github.com/evilmartians/lefthook@latest
#        or: npm i lefthook -g
# Activate:  lefthook install
# Skip once: git commit --no-verify  (use sparingly)

pre-commit:
  parallel: true
  commands:
    go-vet:
      root: "api/"
      run: go vet ./...
    web-lint:
      root: "web/"
      run: pnpm lint

pre-push:
  commands:
    verify-agent:
      run: ./scripts/verify-agent.sh
      # Diff-aware verification — only checks what changed.
      # Bypass: git push --no-verify (or SKIP_VERIFY=1 git push)
