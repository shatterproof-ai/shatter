package sandbox

import (
	"os"
	"path/filepath"
	"strings"
	"testing"
)

func TestBuildSetsidArgv(t *testing.T) {
	t.Run("normal", func(t *testing.T) {
		bwrapArgs := []string{"--ro-bind", "/", "/"}
		argv := buildSetsidArgv("/usr/bin/setsid", "/usr/bin/bwrap", bwrapArgs)

		want := 2 + len(bwrapArgs)
		if len(argv) != want {
			t.Fatalf("expected %d elements, got %d: %v", want, len(argv), argv)
		}
		if argv[0] != "setsid" {
			t.Errorf("argv[0] = %q, want \"setsid\"", argv[0])
		}
		if argv[1] != "/usr/bin/bwrap" {
			t.Errorf("argv[1] = %q, want \"/usr/bin/bwrap\"", argv[1])
		}
		if argv[2] != "--ro-bind" || argv[3] != "/" || argv[4] != "/" {
			t.Errorf("bwrapArgs not preserved: %v", argv[2:])
		}
	})

	t.Run("empty bwrap args", func(t *testing.T) {
		argv := buildSetsidArgv("/usr/bin/setsid", "/usr/bin/bwrap", nil)

		if len(argv) != 2 {
			t.Fatalf("expected 2 elements, got %d: %v", len(argv), argv)
		}
		if argv[0] != "setsid" {
			t.Errorf("argv[0] = %q, want \"setsid\"", argv[0])
		}
		if argv[1] != "/usr/bin/bwrap" {
			t.Errorf("argv[1] = %q, want \"/usr/bin/bwrap\"", argv[1])
		}
	})
}

func TestExecSetsidBwrap_SetsidNotFound(t *testing.T) {
	tmpDir := t.TempDir()

	origPath := os.Getenv("PATH")
	t.Setenv("PATH", tmpDir)
	defer os.Setenv("PATH", origPath)

	err := ExecSetsidBwrap([]string{"--ro-bind", "/", "/"})
	if err == nil {
		t.Fatal("expected error when setsid is not found")
	}
	if !strings.Contains(err.Error(), "setsid not found") {
		t.Errorf("error should contain \"setsid not found\", got: %s", err.Error())
	}
}

func TestExecSetsidBwrap_BwrapNotFound(t *testing.T) {
	tmpDir := t.TempDir()

	// Create a fake setsid that does nothing
	fakeSetsid := filepath.Join(tmpDir, "setsid")
	if err := os.WriteFile(fakeSetsid, []byte("#!/bin/sh\n"), 0o755); err != nil {
		t.Fatal(err)
	}

	origPath := os.Getenv("PATH")
	t.Setenv("PATH", tmpDir)
	defer os.Setenv("PATH", origPath)

	err := ExecSetsidBwrap([]string{"--ro-bind", "/", "/"})
	if err == nil {
		t.Fatal("expected error when bwrap is not found")
	}
	if !strings.Contains(err.Error(), "bwrap not found") {
		t.Errorf("error should contain \"bwrap not found\", got: %s", err.Error())
	}
}

