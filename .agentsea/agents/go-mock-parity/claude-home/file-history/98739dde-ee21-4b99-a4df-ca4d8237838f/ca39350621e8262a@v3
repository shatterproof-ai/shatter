function mkt()
{
    TEMPLATE="$1"
    DIR=""
    if [ -n "$TEMPLATE" ]; then
        DIR=`mktemp -d -t "$TEMPLATE.XXXXXX"`
    else
        DIR=`mktemp -d`
    fi
    cd "$DIR"
}

function ef()
{
    if [ $# -ne 1 ]
    then
        echo "Need to pass exactly one 'find' pattern"
    else "$EDITOR" `find . -iname "$1"`
    fi
}

function zero()
{
    while [ $# -ne 0 ]; do
        echo -n > $1
        shift
    done
}

function mcd()
{
    if [ $# -ne 0 ]
    then
        [ -d $1 ] ||  mkdir -p $1
        cd $1
    else echo "usage: mcd dir-name"
    fi
}

function mct()
{
    if [ $# -ne 0 ]
    then
        mcd /tmp/"$1"
    else
        cd `mktemp -d`
    fi
}

function tgz()
{
    if [ $# -ne 1 ]
    then echo "usage: tgz package.tgz"
    else gunzip -c $1 | tar -xvf -
    fi
}

function finf()
{
    if [ $# -ne 2 ]
    then echo "usage: fink searchstring fileglob"
    else
        find . -type d -a -name 'CVS' -prune -o -name "$2" -exec grep -Hin "$1" \{\} \;
