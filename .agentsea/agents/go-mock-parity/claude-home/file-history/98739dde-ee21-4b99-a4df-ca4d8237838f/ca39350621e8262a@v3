function rotateLog()
{
    if [ $# -ne 1 ]
    then
        echo "Usage: rotateLog logFile"
    else
        startPWD="$PWD"
        baseLogFile=$1
        if [ ! -f "$baseLogFile" ]
        then
            echo "$baseLogFile is not a file"
        else
            combinePaths "$PWD" "$baseLogFile"
            filename=`basename $newPath`
            dirname=`dirname $newPath`
            cd "$dirname"

            let i=0
            while ([ -f "$filename.$i" ])
            do
                let i=$i+1
            done
            mv "$filename" "$filename.$i"
            cd "$startPWD"
        fi
    fi
}

