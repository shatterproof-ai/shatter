.PHONY: build test vet man clean install install-user lint

PREFIX ?= $(HOME)/.local

build:
	go build -o bin/sea ./cmd/sea/

test:
	go test ./...

vet:
	go vet ./...

man: build
	mkdir -p man/man1
	go run ./cmd/gendocs/ man/man1/

clean:
	rm -rf bin/ man/

install: build
	install -m 755 bin/sea /usr/local/bin/sea

install-user: build
	mkdir -p $(PREFIX)/bin
	install -m 755 bin/sea $(PREFIX)/bin/sea

lint: vet
