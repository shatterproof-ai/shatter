- name: Ensure .bash_profile sources .bashrc then WSL agent override
  copy:
    dest: "/home/{{ user }}/.bash_profile"
    content: |
      # Source .bashrc for login shells (e.g. SSH sessions)
      if [ -f "$HOME/.bashrc" ]; then
          . "$HOME/.bashrc"
      fi
      # Override SSH_AUTH_SOCK after .bashrc (so it wins over keychain etc.)
      if [ -f /etc/profile.d/wsl-ssh-agent.sh ]; then
          . /etc/profile.d/wsl-ssh-agent.sh
      fi
    owner: "{{ user }}"
    group: "{{ user }}"
    mode: "0644"
    force: false

- name: Configure git settings
  shell: |
    su -l {{ user }} -c 'git config --global {{ item.key }} "{{ item.value }}"'
  loop:
    - { key: user.name, value: "{{ git_name }}" }
    - { key: user.email, value: "{{ git_email }}" }
    - { key: init.defaultBranch, value: main }
    - { key: pull.rebase, value: "true" }
  changed_when: false

- name: Create project directory
  file:
    path: "/home/{{ user }}/project"
    state: directory
    owner: "{{ user }}"
    group: "{{ user }}"

- name: Create setup directory
  file:
    path: "/home/{{ user }}/setup"
    state: directory
    owner: "{{ user }}"
    group: "{{ user }}"

- name: Create post-provision script
  copy:
    dest: "/home/{{ user }}/setup/post-provision.sh"
    owner: "{{ user }}"
    group: "{{ user }}"
    mode: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      # --- GitHub CLI authentication ---
      if gh auth status &>/dev/null; then
          echo "GitHub CLI: already authenticated."
      else
          echo "Authenticating with GitHub CLI..."
          gh auth login -p ssh -w
      fi

      # --- Clone recently-active repos ---
      echo ""
      echo "Finding recently-active repos for {{ git_email }}..."

      project_dir="$HOME/project"
      mkdir -p "$project_dir"

      repos=$(gh api search/commits \
          --method GET \
          -f "q=author-email:{{ git_email }} committer-date:>$(date -d '60 days ago' +%Y-%m-%d)" \
          -f "sort=committer-date" \
          -f "per_page=100" \
          --jq '[.items[].repository.full_name] | unique | .[]' 2>/dev/null || true)

      if [ -z "$repos" ]; then
          echo "No recently-active repos found."
      else
          for full_name in $repos; do
              repo_name="${full_name##*/}"
              dest="$project_dir/$repo_name"
              if [ -d "$dest" ]; then
                  echo "  $repo_name: already cloned, skipping."
              else
                  echo "  Cloning $full_name..."
                  gh repo clone "$full_name" "$dest"
              fi
          done
      fi

      # --- NetBird VPN authentication ---
      echo ""
      echo "Starting NetBird VPN authentication..."
      sudo netbird up

- name: Clone project repos
  shell: |
    SSH_AUTH_SOCK="{{ lookup('env', 'SSH_AUTH_SOCK') }}"
    GIT_SSH_COMMAND="{{ lookup('env', 'GIT_SSH_COMMAND') }}"
    SSH_ENV=""
    if [ -n "$GIT_SSH_COMMAND" ]; then
      SSH_ENV="GIT_SSH_COMMAND=$GIT_SSH_COMMAND"
    elif [ -n "$SSH_AUTH_SOCK" ]; then
      SSH_ENV="SSH_AUTH_SOCK=$SSH_AUTH_SOCK"
    fi
    dest="/home/{{ user }}/project/{{ item | regex_replace('.*[:/]([^/]+?)(\\.git)?$', '\\1') }}"
    if [ -d "$dest" ]; then
      su -l {{ user }} -c "cd $dest && $SSH_ENV git pull --ff-only"
    else
      su -l {{ user }} -c "$SSH_ENV git clone '{{ item }}' '$dest'"
    fi
  loop: "{{ repos }}"
  when: repos | length > 0
