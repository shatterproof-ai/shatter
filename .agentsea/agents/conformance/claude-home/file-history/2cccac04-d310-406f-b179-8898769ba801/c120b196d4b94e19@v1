import { useState } from 'react'
import { Modal, Text, Group, Stack, SimpleGrid, Loader, Center, Button, Divider } from '@mantine/core'
import { useMediaQuery } from '@mantine/hooks'
import { useQuery } from 'urql'
import { SimilarInstitutions } from './SimilarInstitutions'

const InstitutionDetailQuery = `
  query InstitutionDetail($unitID: String!) {
    institution(unitID: $unitID) {
      unitID
      name
      city
      state
      latitude
      longitude
      institutionType
      enrollment
      graduationRate
      admissionRate
      inStateTuition
      outOfStateTuition
      avgNetPrice
      retentionRate
      studentFacultyRatio
    }
  }
`

interface InstitutionDetailData {
  institution: {
    unitID: string
    name: string
    city: string
    state: string
    latitude: number | null
    longitude: number | null
    institutionType: string | null
    enrollment: number | null
    graduationRate: number | null
    admissionRate: number | null
    inStateTuition: number | null
    outOfStateTuition: number | null
    avgNetPrice: number | null
    retentionRate: number | null
    studentFacultyRatio: number | null
  } | null
}

interface InstitutionDetailProps {
  unitID: string | null
  opened: boolean
  onClose: () => void
}

const INSTITUTION_TYPES: Record<string, string> = {
  '1': 'Public',
  '2': 'Private nonprofit',
  '3': 'Private for-profit',
}

function formatPercent(value: number | null | undefined): string {
  if (value == null) return '—'
  return `${(value * 100).toFixed(1)}%`
}

function formatCurrency(value: number | null | undefined): string {
  if (value == null) return '—'
  return `$${value.toLocaleString()}`
}

function formatNumber(value: number | null | undefined): string {
  if (value == null) return '—'
  return value.toLocaleString()
}

function DetailRow({ label, value }: { label: string; value: string }) {
  return (
    <Group justify="space-between" style={{ borderBottom: '1px solid var(--mantine-color-gray-2)' }} py="xs">
      <Text size="sm" c="dimmed">
        {label}
      </Text>
      <Text size="sm" fw={500}>
        {value}
      </Text>
    </Group>
  )
}

export function InstitutionDetail({ unitID, opened, onClose }: InstitutionDetailProps) {
  const isMobile = useMediaQuery('(max-width: 48em)')
  const [showSimilar, setShowSimilar] = useState(false)

  const [result] = useQuery<InstitutionDetailData>({
    query: InstitutionDetailQuery,
    variables: { unitID: unitID ?? '' },
    pause: !unitID,
  })

  const inst = result.data?.institution

  return (
    <Modal
      opened={opened}
      onClose={onClose}
      fullScreen={isMobile ?? false}
      size="lg"
      title={inst?.name ?? 'Institution Details'}
      aria-label="Institution details"
    >
      {result.fetching && (
        <Center py="xl">
          <Loader size="md" />
        </Center>
      )}
      {result.error && (
        <Text c="red" size="sm">
          Failed to load institution details.
        </Text>
      )}
      {!result.fetching && inst && (
        <Stack gap="md">
          <div>
            <Text size="lg" fw={700} c="brand.9">
              {inst.name}
            </Text>
            <Text size="sm" c="dimmed">
              {inst.city}, {inst.state}
            </Text>
          </div>

          <SimpleGrid cols={{ base: 1, sm: 2 }} spacing="lg">
            <Stack gap={0}>
              <Text size="xs" fw={700} tt="uppercase" c="dimmed" mb="xs">
                Academics
              </Text>
              <DetailRow
                label="Type"
                value={inst.institutionType ? (INSTITUTION_TYPES[inst.institutionType] ?? inst.institutionType) : '—'}
              />
              <DetailRow label="Enrollment" value={formatNumber(inst.enrollment)} />
              <DetailRow
                label="Student-Faculty Ratio"
                value={inst.studentFacultyRatio != null ? `${inst.studentFacultyRatio}:1` : '—'}
              />
            </Stack>

            <Stack gap={0}>
              <Text size="xs" fw={700} tt="uppercase" c="dimmed" mb="xs">
                Cost
              </Text>
              <DetailRow label="In-State Tuition" value={formatCurrency(inst.inStateTuition)} />
              <DetailRow label="Out-of-State Tuition" value={formatCurrency(inst.outOfStateTuition)} />
              <DetailRow label="Avg Net Price" value={formatCurrency(inst.avgNetPrice)} />
            </Stack>

            <Stack gap={0}>
              <Text size="xs" fw={700} tt="uppercase" c="dimmed" mb="xs">
                Outcomes
              </Text>
              <DetailRow label="Admission Rate" value={formatPercent(inst.admissionRate)} />
              <DetailRow label="Graduation Rate" value={formatPercent(inst.graduationRate)} />
              <DetailRow label="Retention Rate" value={formatPercent(inst.retentionRate)} />
            </Stack>
          </SimpleGrid>

          <Divider />

          {!showSimilar ? (
            <Button
              variant="light"
              color="brand"
              size="sm"
              onClick={() => setShowSimilar(true)}
            >
              Find Similar Schools
            </Button>
          ) : (
            <Stack gap="sm">
              <Text size="xs" fw={700} tt="uppercase" c="dimmed">
                Similar Schools
              </Text>
              <SimilarInstitutions unitID={inst.unitID} />
            </Stack>
          )}
        </Stack>
      )}
      {!result.fetching && !result.error && !inst && unitID && (
        <Text c="dimmed" size="sm">
          Institution not found.
        </Text>
      )}
    </Modal>
  )
}
