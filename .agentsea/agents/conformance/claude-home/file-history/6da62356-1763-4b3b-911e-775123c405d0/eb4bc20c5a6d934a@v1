#!/bin/bash
# test_bwrap_isolation.sh
#
# Validates: A process inside bwrap with --ro-bind / / + --tmpfs $HOME
# + selective bind mounts cannot read or write files outside the mounts.
#
# Tests the exact mount pattern agentsea will use for agent sandboxes.

set -euo pipefail

if ! command -v bwrap &>/dev/null; then
  echo "SKIP: bwrap not installed"
  exit 0
fi

# Use a directory NOT under /tmp, because --tmpfs /tmp would hide it.
# In production, agentsea workspaces are under ~/.agentsea, not /tmp.
TESTDIR=$(mktemp -d "$HOME/.agentsea-test-bwrap-XXXXXX")
cleanup() { rm -rf "$TESTDIR"; }
trap cleanup EXIT

# Simulate workspace layout
mkdir -p "$TESTDIR"/{lead/repo,agents/test/repo,mailbox,claude-settings}
echo "lead-secret" > "$TESTDIR/lead/repo/secret.txt"
echo "agent-work" > "$TESTDIR/agents/test/repo/work.txt"
echo '{"test": true}' > "$TESTDIR/claude-settings/settings.json"

AGENT_REPO="$TESTDIR/agents/test/repo"
MAILBOX="$TESTDIR/mailbox"
LEAD_REPO="$TESTDIR/lead/repo"
CLAUDE_SETTINGS="$TESTDIR/claude-settings"
HOME_DIR="$HOME"

ERRORS=0

echo "=== bwrap isolation tests ==="
echo ""

# Test 1: Agent can read its own repo (rw bind mount)
echo "Test 1: Agent can read its own repo..."
RESULT=$(bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --bind "$MAILBOX" "$MAILBOX" \
  --ro-bind "$CLAUDE_SETTINGS" "$HOME_DIR/.claude" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  -- cat "$AGENT_REPO/work.txt" 2>&1) || true

if [ "$RESULT" = "agent-work" ]; then
  echo "  PASS: Agent can read its own repo"
else
  echo "  FAIL: Agent cannot read its own repo: $RESULT"
  ERRORS=$((ERRORS + 1))
fi

# Test 2: Agent can write to its own repo
echo "Test 2: Agent can write to its own repo..."
bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --bind "$MAILBOX" "$MAILBOX" \
  --ro-bind "$CLAUDE_SETTINGS" "$HOME_DIR/.claude" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  -- sh -c "echo 'new-work' > '$AGENT_REPO/new.txt'" 2>&1 || true

if [ -f "$AGENT_REPO/new.txt" ] && [ "$(cat "$AGENT_REPO/new.txt")" = "new-work" ]; then
  echo "  PASS: Agent can write to its own repo"
else
  echo "  FAIL: Agent cannot write to its own repo"
  ERRORS=$((ERRORS + 1))
fi

# Test 3: Agent CANNOT read lead's repo (covered by --tmpfs $HOME which
# wipes everything, and lead repo is under $TESTDIR which is under /)
# We need to specifically tmpfs the lead directory to hide it.
echo "Test 3: Agent cannot read lead's repo..."
RESULT=$(bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --tmpfs "$TESTDIR/lead" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --bind "$MAILBOX" "$MAILBOX" \
  --ro-bind "$CLAUDE_SETTINGS" "$HOME_DIR/.claude" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  -- cat "$LEAD_REPO/secret.txt" 2>&1) || true

if echo "$RESULT" | grep -q "lead-secret"; then
  echo "  FAIL: Agent CAN read lead's repo (isolation broken!)"
  ERRORS=$((ERRORS + 1))
else
  echo "  PASS: Agent cannot read lead's repo"
fi

# Test 4: Agent CANNOT write to system paths (ro-bind)
echo "Test 4: Agent cannot write to system paths..."
RESULT=$(bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --bind "$MAILBOX" "$MAILBOX" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  -- sh -c "echo 'hacked' > /usr/local/test-write 2>&1 || echo 'WRITE_BLOCKED'" 2>&1) || true

if echo "$RESULT" | grep -q "WRITE_BLOCKED\|Read-only file system\|Permission denied"; then
  echo "  PASS: Agent cannot write to system paths"
else
  echo "  FAIL: Agent may be able to write to system paths: $RESULT"
  ERRORS=$((ERRORS + 1))
fi

# Test 5: Agent's /tmp is isolated (tmpfs, doesn't leak to host)
echo "Test 5: Agent's /tmp is isolated..."
MARKER="/tmp/agentsea-bwrap-test-$$"
bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  -- sh -c "echo 'sandbox-tmp' > '$MARKER'" 2>&1 || true

if [ ! -f "$MARKER" ]; then
  echo "  PASS: Agent's /tmp writes don't leak to host"
else
  echo "  FAIL: Agent's /tmp writes visible on host"
  rm -f "$MARKER"
  ERRORS=$((ERRORS + 1))
fi

# Test 6: Agent can write to mailbox
echo "Test 6: Agent can write to mailbox..."
bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --bind "$MAILBOX" "$MAILBOX" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  -- sh -c "echo '{\"msg\": \"hello\"}' > '$MAILBOX/msg.json'" 2>&1 || true

if [ -f "$MAILBOX/msg.json" ] && jq -e '.msg' "$MAILBOX/msg.json" >/dev/null 2>&1; then
  echo "  PASS: Agent can write to mailbox"
else
  echo "  FAIL: Agent cannot write to mailbox"
  ERRORS=$((ERRORS + 1))
fi

# Test 7: Agent can read claude settings (ro)
echo "Test 7: Agent can read claude settings (read-only)..."
RESULT=$(bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --ro-bind "$CLAUDE_SETTINGS" "$HOME_DIR/.claude" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  -- cat "$HOME_DIR/.claude/settings.json" 2>&1) || true

if echo "$RESULT" | jq -e '.test' >/dev/null 2>&1; then
  echo "  PASS: Agent can read claude settings"
else
  echo "  FAIL: Agent cannot read claude settings: $RESULT"
  ERRORS=$((ERRORS + 1))
fi

# Test 8: Agent CANNOT write to claude settings (ro mount)
echo "Test 8: Agent cannot write to claude settings..."
RESULT=$(bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --ro-bind "$CLAUDE_SETTINGS" "$HOME_DIR/.claude" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  -- sh -c "echo 'hacked' > '$HOME_DIR/.claude/settings.json' 2>&1 || echo 'WRITE_BLOCKED'" 2>&1) || true

if echo "$RESULT" | grep -q "WRITE_BLOCKED\|Read-only file system\|Permission denied"; then
  echo "  PASS: Agent cannot write to claude settings"
else
  echo "  FAIL: Agent may be able to write to claude settings: $RESULT"
  ERRORS=$((ERRORS + 1))
fi

# Test 9: SSH_AUTH_SOCK is cleared
echo "Test 9: SSH_AUTH_SOCK is cleared..."
RESULT=$(bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  --setenv SSH_AUTH_SOCK "" \
  -- sh -c 'echo "SSH_AUTH_SOCK=[$SSH_AUTH_SOCK]"' 2>&1) || true

if echo "$RESULT" | grep -q 'SSH_AUTH_SOCK=\[\]'; then
  echo "  PASS: SSH_AUTH_SOCK is empty inside sandbox"
else
  echo "  FAIL: SSH_AUTH_SOCK may still be set: $RESULT"
  ERRORS=$((ERRORS + 1))
fi

# Test 10: Git works inside sandbox
echo "Test 10: Git works inside sandbox..."
RESULT=$(bwrap \
  --ro-bind / / \
  --tmpfs "$HOME_DIR" \
  --bind "$AGENT_REPO" "$AGENT_REPO" \
  --tmpfs /tmp \
  --proc /proc --dev /dev \
  --setenv HOME "$HOME_DIR" \
  --setenv GIT_AUTHOR_NAME "test" \
  --setenv GIT_AUTHOR_EMAIL "test@test" \
  --setenv GIT_COMMITTER_NAME "test" \
  --setenv GIT_COMMITTER_EMAIL "test@test" \
  --chdir "$AGENT_REPO" \
  -- sh -c 'git init -q && echo test > file.txt && git add file.txt && git commit -q -m "test" && echo GIT_OK' 2>&1) || true

if echo "$RESULT" | grep -q "GIT_OK"; then
  echo "  PASS: Git init/add/commit works inside sandbox"
else
  echo "  FAIL: Git operations failed inside sandbox: $RESULT"
  ERRORS=$((ERRORS + 1))
fi

echo ""
if [ $ERRORS -eq 0 ]; then
  echo "ALL ISOLATION TESTS PASSED ($((10)) tests)"
  exit 0
else
  echo "$ERRORS of 10 ISOLATION TEST(S) FAILED"
  exit 1
fi
