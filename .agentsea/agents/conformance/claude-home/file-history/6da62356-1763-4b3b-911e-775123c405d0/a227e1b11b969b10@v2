.PHONY: build clean help install install-user lint man test vet

PREFIX ?= $(HOME)/.local

##@ Key Targets

help: ## Show this help
	@echo "Usage: make [target]"
	@echo ""
	@echo "Key Targets:"
	@grep -E '^[a-zA-Z_-]+:.*## ' $(MAKEFILE_LIST) | \
		sort | awk 'BEGIN {FS = ":.*## "} {printf "  \033[36m%-15s\033[0m %s\n", $$1, $$2}'
	@echo ""
	@echo "Other Targets:"
	@grep -E '^[a-zA-Z_-]+:.*[^#]# [^#]' $(MAKEFILE_LIST) | \
		sort | awk 'BEGIN {FS = ":.*# "} {printf "  \033[36m%-15s\033[0m %s\n", $$1, $$2}'

build: ## Build the sea binary
	go build -o bin/sea ./cmd/sea/

clean: ## Remove build artifacts
	rm -rf bin/ man/

install: build ## Install sea to /usr/local/bin
	install -m 755 bin/sea /usr/local/bin/sea

lint: vet ## Run linters


test: ## Run all tests
	go test ./...

##@ Other Targets

install-user: build # Install sea to ~/.local/bin
	mkdir -p $(PREFIX)/bin
	install -m 755 bin/sea $(PREFIX)/bin/sea

man: build # Generate man pages
	mkdir -p man/man1
	go run ./cmd/gendocs/ man/man1/

vet: # Run go vet
	go vet ./...
