{
  "name": "shatter-ts",
  "version": "0.1.0",
  "description": "TypeScript frontend for the Shatter concolic execution engine",
  "main": "dist/main.js",
  "bin": {
    "shatter-ts": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/main.ts --bundle --platform=node --target=node22 --outfile=dist/bundle.js",
    "start": "node dist/main.js",
    "test": "jest"
  },
  "dependencies": {
    "@extism/extism": "^2.0.0-rc13",
    "pino": "^10.3.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "fast-check": "^3.22.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2"
  }
}
