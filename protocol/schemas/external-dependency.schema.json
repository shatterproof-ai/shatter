{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shatter.dev/protocol/external-dependency.schema.json",
  "title": "ExternalDependency",
  "description": "An external dependency detected during analysis.",
  "type": "object",
  "required": ["kind", "symbol", "source_module", "return_type", "param_types", "call_sites"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["function_call", "method_call", "property_access", "module_import"],
      "description": "The kind of dependency."
    },
    "symbol": {
      "type": "string",
      "description": "Fully qualified symbol name."
    },
    "source_module": {
      "type": "string",
      "description": "Module or package the symbol is imported from."
    },
    "return_type": {
      "$ref": "type-info.schema.json",
      "description": "Return type for generating mock values."
    },
    "param_types": {
      "type": "array",
      "items": { "$ref": "type-info.schema.json" },
      "description": "Parameter types for validating mock calls."
    },
    "call_sites": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "Line numbers where this dependency is called."
    }
  }
}
