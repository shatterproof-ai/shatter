{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shatter.dev/protocol/response.schema.json",
  "title": "Shatter Protocol Response",
  "description": "A response message sent from a language frontend to the core engine.",
  "type": "object",
  "required": ["protocol_version", "id", "status"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "description": "Protocol version for compatibility checking.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "integer",
      "minimum": 0,
      "description": "Request ID this response corresponds to."
    },
    "timing": {
      "$ref": "#/$defs/timing_summary",
      "description": "Optional timing summary for this frontend command."
    },
    "status": {
      "type": "string",
      "enum": [
        "handshake",
        "analyze",
        "instrument",
        "prepare",
        "execute",
        "setup",
        "teardown_ack",
        "generate",
        "shutdown_ack",
        "invocation_plan",
        "error"
      ],
      "description": "The response type, matching the originating command."
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/handshake_response" },
    { "$ref": "#/$defs/analyze_response" },
    { "$ref": "#/$defs/instrument_response" },
    { "$ref": "#/$defs/prepare_response" },
    { "$ref": "#/$defs/execute_response" },
    { "$ref": "#/$defs/setup_response" },
    { "$ref": "#/$defs/teardown_ack_response" },
    { "$ref": "#/$defs/generate_response" },
    { "$ref": "#/$defs/shutdown_ack_response" },
    { "$ref": "#/$defs/invocation_plan_response" },
    { "$ref": "#/$defs/error_response" }
  ],
  "$defs": {
    "handshake_response": {
      "type": "object",
      "properties": {
        "status": { "const": "handshake" },
        "frontend_version": {
          "type": "string",
          "description": "Protocol version the frontend supports."
        },
        "language": {
          "type": "string",
          "description": "Language this frontend handles (e.g., 'typescript', 'go')."
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Capabilities supported by the frontend."
        }
      },
      "required": ["status", "frontend_version", "language", "capabilities"]
    },
    "analyze_response": {
      "type": "object",
      "properties": {
        "status": { "const": "analyze" },
        "functions": {
          "type": "array",
          "items": { "$ref": "function-analysis.schema.json" },
          "description": "Functions found and analyzed."
        }
      },
      "required": ["status", "functions"]
    },
    "instrument_response": {
      "type": "object",
      "properties": {
        "status": { "const": "instrument" },
        "instrumented": {
          "type": "boolean",
          "description": "Whether instrumentation succeeded."
        },
        "output_file": {
          "type": ["string", "null"],
          "description": "Path to the instrumented output file, if applicable."
        },
        "instrumentable_line_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of executable statement lines the instrumentor inserted record calls for."
        }
      },
      "required": ["status", "instrumented"]
    },
    "prepare_response": {
      "type": "object",
      "properties": {
        "status": { "const": "prepare" },
        "prepare_id": {
          "type": "string",
          "description": "Opaque handle for subsequent execute calls. Pass as prepare_id in execute requests."
        }
      },
      "required": ["status", "prepare_id"]
    },
    "execute_response": {
      "type": "object",
      "properties": {
        "status": { "const": "execute" },
        "return_value": {
          "description": "Return value from the function, if it returned normally."
        },
        "thrown_error": {
          "oneOf": [{ "$ref": "error-info.schema.json" }, { "type": "null" }],
          "description": "Error thrown during execution, if any."
        },
        "branch_path": {
          "type": "array",
          "items": { "$ref": "branch-decision.schema.json" },
          "description": "Branch decisions recorded during execution."
        },
        "lines_executed": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Source lines executed."
        },
        "calls_to_external": {
          "type": "array",
          "items": { "$ref": "external-call.schema.json" },
          "description": "Calls to external dependencies observed."
        },
        "path_constraints": {
          "type": "array",
          "items": { "$ref": "sym-constraint.schema.json" },
          "description": "Symbolic path constraints collected."
        },
        "scope_events": {
          "type": "array",
          "items": { "$ref": "#/$defs/trace_event" },
          "description": "Scope-annotated execution trace (branches plus loop/call markers). When non-empty, enables scope-aware path collapsing."
        },
        "loop_body_states": {
          "type": "array",
          "items": { "$ref": "#/$defs/loop_body_state" },
          "description": "Per-iteration symbolic snapshots for supported loop bodies."
        },
        "side_effects": {
          "type": "array",
          "items": { "$ref": "side-effect.schema.json" },
          "description": "Side effects observed during execution."
        },
        "capture_truncation": {
          "type": ["object", "null"],
          "description": "Truncation metadata for captured side effects, present only when truncation was applied.",
          "properties": {
            "was_truncated": {
              "type": "boolean",
              "description": "Whether the side-effect output was truncated."
            },
            "original_lines": {
              "type": "integer",
              "minimum": 0,
              "description": "Original number of console output lines before truncation."
            },
            "original_bytes": {
              "type": "integer",
              "minimum": 0,
              "description": "Original byte count of console output before truncation."
            }
          },
          "required": ["was_truncated", "original_lines", "original_bytes"]
        },
        "performance": {
          "$ref": "performance-metrics.schema.json",
          "description": "Performance metrics."
        },
        "discovered_dependencies": {
          "type": "array",
          "items": { "$ref": "#/$defs/discovered_dependency" },
          "description": "Dependencies discovered at execution time that static analysis missed."
        },
        "connection_failures": {
          "type": "array",
          "items": { "$ref": "#/$defs/connection_failure" },
          "description": "Connection failures detected during external calls; used to trigger LiveFirst fallback."
        },
        "outcome": {
          "$ref": "invocation-outcome.schema.json",
          "description": "Structured invocation outcome. Currently emitted by the Go frontend; absent from TS/Rust frontends."
        },
        "runtime_crypto_boundaries": {
          "type": "array",
          "description": "Cryptographic boundaries intercepted at runtime. Present when the function called a known encrypt/decrypt API; the core engine uses these for boundary splitting.",
          "items": {
            "type": "object",
            "properties": {
              "boundary_id": {
                "type": "string",
                "description": "Stable identifier for this boundary within the execution trace, e.g. 'cb-0'."
              },
              "kind": {
                "type": "string",
                "enum": ["encrypt", "decrypt"],
                "description": "Whether this is an encrypt or decrypt boundary."
              },
              "function_name": {
                "type": "string",
                "description": "Function name as it appears in source, e.g. 'createDecipheriv'."
              },
              "algorithm": {
                "type": "string",
                "description": "Algorithm string captured at runtime, e.g. 'aes-256-cbc'."
              },
              "ciphertext_param_index": {
                "type": "integer",
                "description": "Index of the argument holding the ciphertext. Absent when ciphertext is passed to a separate method call."
              },
              "key_value": {
                "type": "string",
                "description": "Base64-encoded key bytes captured at runtime."
              },
              "iv_value": {
                "type": "string",
                "description": "Base64-encoded IV bytes captured at runtime."
              }
            },
            "required": ["boundary_id", "kind", "function_name"]
          }
        }
      },
      "required": [
        "status",
        "branch_path",
        "lines_executed",
        "calls_to_external",
        "path_constraints",
        "side_effects",
        "performance"
      ]
    },
    "setup_response": {
      "type": "object",
      "properties": {
        "status": { "const": "setup" },
        "setup_context": {
          "description": "Opaque context value to pass to subsequent execute and teardown commands."
        }
      },
      "required": ["status", "setup_context"]
    },
    "teardown_ack_response": {
      "type": "object",
      "properties": {
        "status": { "const": "teardown_ack" }
      },
      "required": ["status"]
    },
    "generate_response": {
      "type": "object",
      "properties": {
        "status": { "const": "generate" },
        "value": {
          "description": "The generated value."
        },
        "generator_id": {
          "type": "string",
          "description": "Human-readable label for this generated value (e.g. 'postgres-test-db')."
        },
        "recipe": {
          "description": "Serializable recipe for replaying this generation. For WASM generators where value is already JSON, this may be omitted."
        }
      },
      "required": ["status", "value", "generator_id"]
    },
    "shutdown_ack_response": {
      "type": "object",
      "properties": {
        "status": { "const": "shutdown_ack" }
      },
      "required": ["status"]
    },
    "invocation_plan_response": {
      "type": "object",
      "description": "Successful planner result for a get_invocation_plan request.",
      "properties": {
        "status": { "const": "invocation_plan" },
        "invocation_plans": {
          "type": "array",
          "items": { "$ref": "#/$defs/invocation_plan" },
          "description": "Resolved plans, one per satisfiable requirement. Order is arbitrary."
        },
        "unsatisfied_requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/unsatisfied_requirement" },
          "description": "Requirements the planner could not satisfy, each annotated with a reason."
        }
      },
      "required": ["status", "invocation_plans"]
    },
    "error_response": {
      "type": "object",
      "properties": {
        "status": { "const": "error" },
        "code": {
          "type": "string",
          "enum": [
            "file_not_found",
            "function_not_found",
            "parse_error",
            "instrumentation_failed",
            "execution_timeout",
            "execution_crash",
            "version_mismatch",
            "invalid_request",
            "compilation_error",
            "internal_error",
            "not_supported",
            "preflight_failed"
          ],
          "description": "Machine-readable error code. Mirrors shatter-core protocol::ErrorCode."
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message."
        },
        "details": {
          "description": "Additional error details (e.g., stack trace, source location)."
        }
      },
      "required": ["status", "code", "message"]
    },
    "outcome_status": {
      "$ref": "outcome-status.schema.json"
    },
    "invocation_outcome": {
      "$ref": "invocation-outcome.schema.json"
    },
    "trace_event": {
      "type": "object",
      "description": "One entry in the scope-annotated execution trace. Tagged by `type`: branch decisions or scope events.",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["branch", "scope"]
        }
      },
      "required": ["type"]
    },
    "loop_body_state": {
      "type": "object",
      "description": "Per-iteration symbolic snapshot for one loop body.",
      "properties": {
        "loop_id": {
          "type": "integer",
          "minimum": 0,
          "description": "Matches the loop_id in scope events and LoopInfo."
        },
        "iteration": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based iteration index in execution order."
        },
        "locals": {
          "type": "object",
          "additionalProperties": { "$ref": "sym-expr.schema.json" },
          "description": "Symbolic expressions for tracked identifier locals at this iteration."
        }
      },
      "required": ["loop_id", "iteration"]
    },
    "discovered_dependency": {
      "type": "object",
      "description": "A dependency discovered at execution time that static analysis missed.",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "Fully qualified symbol or module name."
        },
        "source_module": {
          "type": "string",
          "description": "Module the dependency was imported from."
        },
        "kind": {
          "type": "string",
          "enum": ["unmocked_import", "subprocess_spawn", "stubbed_import"],
          "description": "How the dependency was detected."
        },
        "is_subprocess_spawn": {
          "type": "boolean",
          "description": "Whether this dependency spawns a subprocess."
        }
      },
      "required": ["symbol", "source_module", "kind", "is_subprocess_spawn"]
    },
    "connection_failure": {
      "type": "object",
      "description": "A connection failure detected during execution, enabling LiveFirst fallback.",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "External symbol whose call failed (e.g. 'http:fetch')."
        },
        "error_kind": {
          "type": "string",
          "description": "Failure category (e.g. 'connection_refused', 'dns_failure', 'auth_error', 'timeout', 'other')."
        },
        "message": {
          "type": "string",
          "description": "Original error message from the failing call."
        }
      },
      "required": ["symbol", "error_kind", "message"]
    },
    "value_plan": {
      "type": "object",
      "properties": {
        "param_index": {
          "type": "integer",
          "minimum": 0
        },
        "param_name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["literal", "zero", "random", "symbolic", "runtime_value"]
        },
        "literal": {},
        "type_hint": {
          "type": "string"
        }
      },
      "required": ["param_index", "param_name", "kind"]
    },
    "receiver_field_plan": {
      "type": "object",
      "description": "Typed plan for populating one field on a constructed receiver before invocation (str-mhinv.1).",
      "properties": {
        "path": {
          "type": "array",
          "items": { "type": "string" }
        },
        "kind": {
          "type": "string",
          "enum": ["literal", "zero", "random", "symbolic", "runtime_value"]
        },
        "literal": {},
        "type_hint": { "type": "string" }
      },
      "required": ["path", "kind"]
    },
    "invocation_plan": {
      "type": "object",
      "properties": {
        "target_id": { "type": "string" },
        "receiver_kind": { "type": "string" },
        "generic_type_args": {
          "type": "array",
          "items": { "type": "string" }
        },
        "argument_plans": {
          "type": "array",
          "items": { "$ref": "#/$defs/value_plan" }
        },
        "constructor_arg_plans": {
          "type": "array",
          "items": { "$ref": "#/$defs/value_plan" }
        },
        "receiver_field_plans": {
          "type": "array",
          "items": { "$ref": "#/$defs/receiver_field_plan" }
        },
        "priority": { "type": "integer" },
        "label": { "type": "string" }
      },
      "required": ["target_id", "receiver_kind", "argument_plans", "priority"]
    },
    "unsatisfied_requirement": {
      "type": "object",
      "description": "Planning failure for one target.",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "no_constructor",
            "interface_receiver",
            "generic_unconstrained",
            "cgo_dependency",
            "complex_type"
          ],
          "description": "Failure classification."
        },
        "target_id": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      },
      "required": ["kind", "target_id"]
    },
    "timing_summary": {
      "type": "object",
      "description": "Optional timing summary emitted by a frontend command.",
      "properties": {
        "phases": {
          "type": "array",
          "items": { "$ref": "#/$defs/timing_phase_summary" }
        }
      }
    },
    "timing_phase_summary": {
      "type": "object",
      "properties": {
        "phase_path": { "type": "string" },
        "total_ms": { "type": "number" },
        "self_ms": { "type": "number" },
        "count": { "type": "integer", "minimum": 0 },
        "attributes": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "required": ["phase_path", "total_ms"]
    }
  }
}
