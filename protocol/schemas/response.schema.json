{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shatter.dev/protocol/response.schema.json",
  "title": "Shatter Protocol Response",
  "description": "A response message sent from a language frontend to the core engine.",
  "type": "object",
  "required": ["protocol_version", "id", "status"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "description": "Protocol version for compatibility checking.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "integer",
      "minimum": 0,
      "description": "Request ID this response corresponds to."
    },
    "status": {
      "type": "string",
      "enum": ["handshake", "analyze", "instrument", "prepare", "execute", "setup", "teardown_ack", "generate", "shutdown_ack", "error"],
      "description": "The response type, matching the originating command."
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/handshake_response" },
    { "$ref": "#/$defs/analyze_response" },
    { "$ref": "#/$defs/instrument_response" },
    { "$ref": "#/$defs/prepare_response" },
    { "$ref": "#/$defs/execute_response" },
    { "$ref": "#/$defs/setup_response" },
    { "$ref": "#/$defs/teardown_ack_response" },
    { "$ref": "#/$defs/generate_response" },
    { "$ref": "#/$defs/shutdown_ack_response" },
    { "$ref": "#/$defs/error_response" }
  ],
  "$defs": {
    "handshake_response": {
      "type": "object",
      "properties": {
        "status": { "const": "handshake" },
        "frontend_version": {
          "type": "string",
          "description": "Protocol version the frontend supports."
        },
        "language": {
          "type": "string",
          "description": "Language this frontend handles (e.g., 'typescript', 'go')."
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Capabilities supported by the frontend."
        }
      },
      "required": ["status", "frontend_version", "language", "capabilities"]
    },
    "analyze_response": {
      "type": "object",
      "properties": {
        "status": { "const": "analyze" },
        "functions": {
          "type": "array",
          "items": { "$ref": "function-analysis.schema.json" },
          "description": "Functions found and analyzed."
        }
      },
      "required": ["status", "functions"]
    },
    "instrument_response": {
      "type": "object",
      "properties": {
        "status": { "const": "instrument" },
        "instrumented": {
          "type": "boolean",
          "description": "Whether instrumentation succeeded."
        },
        "output_file": {
          "type": ["string", "null"],
          "description": "Path to the instrumented output file, if applicable."
        },
        "instrumentable_line_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of executable statement lines the instrumentor inserted record calls for."
        }
      },
      "required": ["status", "instrumented"]
    },
    "prepare_response": {
      "type": "object",
      "properties": {
        "status": { "const": "prepare" },
        "prepare_id": {
          "type": "string",
          "description": "Opaque handle for subsequent execute calls. Pass as prepare_id in execute requests."
        }
      },
      "required": ["status", "prepare_id"]
    },
    "execute_response": {
      "type": "object",
      "properties": {
        "status": { "const": "execute" },
        "return_value": {
          "description": "Return value from the function, if it returned normally."
        },
        "thrown_error": {
          "oneOf": [
            { "$ref": "error-info.schema.json" },
            { "type": "null" }
          ],
          "description": "Error thrown during execution, if any."
        },
        "branch_path": {
          "type": "array",
          "items": { "$ref": "branch-decision.schema.json" },
          "description": "Branch decisions recorded during execution."
        },
        "lines_executed": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Source lines executed."
        },
        "calls_to_external": {
          "type": "array",
          "items": { "$ref": "external-call.schema.json" },
          "description": "Calls to external dependencies observed."
        },
        "path_constraints": {
          "type": "array",
          "items": { "$ref": "sym-constraint.schema.json" },
          "description": "Symbolic path constraints collected."
        },
        "side_effects": {
          "type": "array",
          "items": { "$ref": "side-effect.schema.json" },
          "description": "Side effects observed during execution."
        },
        "capture_truncation": {
          "type": "object",
          "description": "Truncation metadata for captured side effects, present only when truncation was applied.",
          "properties": {
            "was_truncated": {
              "type": "boolean",
              "description": "Whether the side-effect output was truncated."
            },
            "original_lines": {
              "type": "integer",
              "minimum": 0,
              "description": "Original number of console output lines before truncation."
            },
            "original_bytes": {
              "type": "integer",
              "minimum": 0,
              "description": "Original byte count of console output before truncation."
            }
          },
          "required": ["was_truncated", "original_lines", "original_bytes"]
        },
        "performance": {
          "$ref": "performance-metrics.schema.json",
          "description": "Performance metrics."
        },
        "runtime_crypto_boundaries": {
          "type": "array",
          "description": "Cryptographic boundaries intercepted at runtime. Present when the function called a known encrypt/decrypt API; the core engine uses these for boundary splitting.",
          "items": {
            "type": "object",
            "properties": {
              "boundary_id": {
                "type": "string",
                "description": "Stable identifier for this boundary within the execution trace, e.g. 'cb-0'."
              },
              "kind": {
                "type": "string",
                "enum": ["encrypt", "decrypt"],
                "description": "Whether this is an encrypt or decrypt boundary."
              },
              "function_name": {
                "type": "string",
                "description": "Function name as it appears in source, e.g. 'createDecipheriv'."
              },
              "algorithm": {
                "type": "string",
                "description": "Algorithm string captured at runtime, e.g. 'aes-256-cbc'."
              },
              "ciphertext_param_index": {
                "type": "integer",
                "description": "Index of the argument holding the ciphertext. Absent when ciphertext is passed to a separate method call."
              },
              "key_value": {
                "type": "string",
                "description": "Base64-encoded key bytes captured at runtime."
              },
              "iv_value": {
                "type": "string",
                "description": "Base64-encoded IV bytes captured at runtime."
              }
            },
            "required": ["boundary_id", "kind", "function_name"]
          }
        }
      },
      "required": ["status", "branch_path", "lines_executed", "calls_to_external", "path_constraints", "side_effects", "performance"]
    },
    "setup_response": {
      "type": "object",
      "properties": {
        "status": { "const": "setup" },
        "setup_context": {
          "description": "Opaque context value to pass to subsequent execute and teardown commands."
        }
      },
      "required": ["status", "setup_context"]
    },
    "teardown_ack_response": {
      "type": "object",
      "properties": {
        "status": { "const": "teardown_ack" }
      },
      "required": ["status"]
    },
    "generate_response": {
      "type": "object",
      "properties": {
        "status": { "const": "generate" },
        "value": {
          "description": "The generated value."
        },
        "generator_id": {
          "type": "string",
          "description": "Human-readable label for this generated value (e.g. 'postgres-test-db')."
        },
        "recipe": {
          "description": "Serializable recipe for replaying this generation. For WASM generators where value is already JSON, this may be omitted."
        }
      },
      "required": ["status", "value", "generator_id"]
    },
    "shutdown_ack_response": {
      "type": "object",
      "properties": {
        "status": { "const": "shutdown_ack" }
      },
      "required": ["status"]
    },
    "error_response": {
      "type": "object",
      "properties": {
        "status": { "const": "error" },
        "code": {
          "type": "string",
          "enum": [
            "file_not_found", "function_not_found", "parse_error",
            "instrumentation_failed", "execution_timeout", "execution_crash",
            "version_mismatch", "invalid_request", "compilation_error",
            "internal_error", "not_supported"
          ],
          "description": "Machine-readable error code."
        },
        "message": {
          "type": "string",
          "description": "Human-readable error message."
        },
        "details": {
          "description": "Additional error details (e.g., stack trace, source location)."
        }
      },
      "required": ["status", "code", "message"]
    }
  }
}
