{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shatter.dev/protocol/type-info.schema.json",
  "title": "TypeInfo",
  "description": "Describes the type of a value, as reported by a language frontend.",
  "type": "object",
  "required": ["kind"],
  "properties": {
    "kind": {
      "type": "string",
      "enum": ["int", "float", "str", "bool", "array", "object", "union", "nullable", "opaque", "unknown"]
    }
  },
  "oneOf": [
    {
      "properties": {
        "kind": { "const": "int" },
        "int_width": {
          "type": "integer",
          "enum": [8, 16, 32, 64, 128],
          "description": "Optional bit width of the integer type. Carried by frontends that know the source width (e.g. the Rust analyzer maps u8 -> 8). Absent means unspecified; the core treats unspecified as full-i64 range."
        },
        "int_signed": {
          "type": "boolean",
          "description": "Optional signedness of the integer type. Absent means unspecified."
        }
      },
      "required": ["kind"]
    },
    {
      "properties": { "kind": { "const": "float" } },
      "required": ["kind"]
    },
    {
      "properties": { "kind": { "const": "str" } },
      "required": ["kind"]
    },
    {
      "properties": { "kind": { "const": "bool" } },
      "required": ["kind"]
    },
    {
      "properties": {
        "kind": { "const": "array" },
        "element": { "$ref": "#", "description": "Element type." }
      },
      "required": ["kind", "element"]
    },
    {
      "properties": {
        "kind": { "const": "object" },
        "fields": {
          "type": "array",
          "items": {
            "type": "array",
            "prefixItems": [
              { "type": "string" },
              { "$ref": "#" }
            ],
            "items": false,
            "minItems": 2,
            "maxItems": 2
          },
          "description": "Field name and type pairs."
        }
      },
      "required": ["kind", "fields"]
    },
    {
      "properties": {
        "kind": { "const": "union" },
        "variants": {
          "type": "array",
          "items": { "$ref": "#" },
          "description": "Possible type variants."
        },
        "enum_values": {
          "type": "array",
          "items": { "type": ["string", "number", "boolean"] },
          "description": "Optional concrete value domain for named enum-like types (Go const sets, TS string-literal unions, Rust fieldless enums). When present the input generator draws valid members directly, mixing in off-domain probes from `variants` so decoder-rejection paths stay covered (str-pjlc1)."
        }
      },
      "required": ["kind", "variants"]
    },
    {
      "properties": {
        "kind": { "const": "nullable" },
        "inner": { "$ref": "#", "description": "Non-null type." }
      },
      "required": ["kind", "inner"]
    },
    {
      "properties": {
        "kind": { "const": "opaque" },
        "label": {
          "type": "string",
          "description": "Human-readable name of the opaque resource type (e.g. \"net.Socket\", \"fs.FileHandle\")."
        }
      },
      "required": ["kind", "label"]
    },
    {
      "properties": { "kind": { "const": "unknown" } },
      "required": ["kind"]
    }
  ]
}
