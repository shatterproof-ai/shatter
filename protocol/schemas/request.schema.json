{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shatter.dev/protocol/request.schema.json",
  "title": "Shatter Protocol Request",
  "description": "A request message sent from the core engine to a language frontend.",
  "type": "object",
  "required": ["protocol_version", "id", "command"],
  "properties": {
    "protocol_version": {
      "type": "string",
      "description": "Protocol version for compatibility checking.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "type": "integer",
      "minimum": 0,
      "description": "Unique identifier for correlating responses to requests."
    },
    "command": {
      "type": "string",
      "enum": ["handshake", "analyze", "instrument", "prepare", "execute", "setup", "teardown", "generate", "get_invocation_plan", "shutdown"],
      "description": "The command to execute."
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/handshake_request" },
    { "$ref": "#/$defs/analyze_request" },
    { "$ref": "#/$defs/instrument_request" },
    { "$ref": "#/$defs/prepare_request" },
    { "$ref": "#/$defs/execute_request" },
    { "$ref": "#/$defs/setup_request" },
    { "$ref": "#/$defs/teardown_request" },
    { "$ref": "#/$defs/generate_request" },
    { "$ref": "#/$defs/get_invocation_plan_request" },
    { "$ref": "#/$defs/shutdown_request" }
  ],
  "$defs": {
    "handshake_request": {
      "type": "object",
      "properties": {
        "command": { "const": "handshake" },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Capabilities supported by the core."
        }
      },
      "required": ["command", "capabilities"]
    },
    "analyze_request": {
      "type": "object",
      "properties": {
        "command": { "const": "analyze" },
        "file": {
          "type": "string",
          "description": "Path to the source file."
        },
        "function": {
          "type": ["string", "null"],
          "description": "Name of the function to analyze. If null/absent, analyze all exported functions."
        },
        "project_root": {
          "type": ["string", "null"],
          "description": "Path to the detected project root directory."
        },
        "execution_profile": {
          "$ref": "#/$defs/execution_profile",
          "description": "Opaque ordered adapter descriptors selected for this target."
        }
      },
      "required": ["command", "file"]
    },
    "instrument_request": {
      "type": "object",
      "properties": {
        "command": { "const": "instrument" },
        "file": {
          "type": "string",
          "description": "Path to the source file."
        },
        "function": {
          "type": "string",
          "description": "Name of the function to instrument."
        },
        "mocks": {
          "type": "array",
          "items": { "$ref": "mock-config.schema.json" },
          "description": "Mock configurations for external dependencies."
        },
        "project_root": {
          "type": ["string", "null"],
          "description": "Path to the detected project root directory."
        },
        "execution_profile": {
          "$ref": "#/$defs/execution_profile",
          "description": "Opaque ordered adapter descriptors selected for this target."
        },
        "plan": {
          "oneOf": [
            { "$ref": "#/$defs/invocation_plan" },
            { "type": "null" }
          ],
          "description": "Optional invocation plan used to prepare plan-specific launcher artifacts."
        }
      },
      "required": ["command", "file", "function", "mocks"]
    },
    "prepare_request": {
      "type": "object",
      "properties": {
        "command": { "const": "prepare" },
        "file": {
          "type": "string",
          "description": "Path to the source file."
        },
        "function": {
          "type": "string",
          "description": "Name of the function to prepare."
        },
        "mocks": {
          "type": "array",
          "items": { "$ref": "mock-config.schema.json" },
          "description": "Mock configurations for external dependencies."
        },
        "project_root": {
          "type": ["string", "null"],
          "description": "Path to the detected project root directory."
        },
        "execution_profile": {
          "$ref": "#/$defs/execution_profile",
          "description": "Opaque ordered adapter descriptors selected for this target."
        }
      },
      "required": ["command", "file", "function", "mocks"]
    },
    "execute_request": {
      "type": "object",
      "properties": {
        "command": { "const": "execute" },
        "function": {
          "type": "string",
          "description": "Fully qualified function identifier."
        },
        "inputs": {
          "type": "array",
          "description": "Input values for the function parameters (JSON-encoded)."
        },
        "mocks": {
          "type": "array",
          "items": { "$ref": "mock-config.schema.json" },
          "description": "Mock configurations for external dependencies."
        },
        "setup_context": {
          "oneOf": [
            { "$ref": "setup-context-stack.schema.json" },
            { "type": "null" }
          ],
          "description": "Stack of active setup contexts from enclosing setup commands."
        },
        "prepare_id": {
          "type": "string",
          "description": "Opaque handle from a prior prepare call. When present, reuse cached build artifacts."
        },
        "capture": {
          "type": "boolean",
          "description": "When false, the frontend skips side-effect capture (console/process interception) for lower per-execute overhead. Defaults to true. Non-capture outputs (branch_path, lines_executed, return_value, thrown_error) remain correct.",
          "default": true
        },
        "execution_profile": {
          "$ref": "#/$defs/execution_profile",
          "description": "Opaque ordered adapter descriptors selected for this target."
        },
        "plan": {
          "oneOf": [
            { "$ref": "#/$defs/invocation_plan" },
            { "type": "null" }
          ],
          "description": "Optional invocation plan from get_invocation_plan."
        }
      },
      "required": ["command", "function", "inputs", "mocks"]
    },
    "setup_request": {
      "type": "object",
      "properties": {
        "command": { "const": "setup" },
        "file": {
          "type": "string",
          "description": "Path to the setup file."
        },
        "scope": {
          "type": "string",
          "description": "Identifier for this setup scope (function name, file path, or session label)."
        },
        "level": {
          "$ref": "setup-level.schema.json",
          "description": "Lifecycle level: session, file, function, or execution."
        },
        "project_root": {
          "type": ["string", "null"],
          "description": "Path to the detected project root directory."
        },
        "parent_context": {
          "oneOf": [
            { "$ref": "setup-context-stack.schema.json" },
            { "type": "null" }
          ],
          "description": "Contexts from enclosing setup levels, outermost first."
        },
        "execution_profile": {
          "$ref": "#/$defs/execution_profile",
          "description": "Opaque ordered adapter descriptors selected for this target."
        }
      },
      "required": ["command", "file", "scope", "level"]
    },
    "teardown_request": {
      "type": "object",
      "properties": {
        "command": { "const": "teardown" },
        "scope": {
          "type": "string",
          "description": "Scope identifier matching the corresponding setup command."
        },
        "level": {
          "$ref": "setup-level.schema.json",
          "description": "Lifecycle level: session, file, function, or execution."
        }
      },
      "required": ["command", "scope", "level"]
    },
    "generate_request": {
      "type": "object",
      "properties": {
        "command": { "const": "generate" },
        "file": {
          "type": "string",
          "description": "Path to the generator file."
        },
        "name": {
          "type": "string",
          "description": "Name of the type or parameter to generate a value for."
        },
        "kind": {
          "type": "string",
          "enum": ["type_name", "param_name"],
          "description": "Whether this generator targets a type name or a parameter name."
        },
        "recipe": {
          "description": "Reconstruction recipe from a previous generation. When present, the generator should reproduce the value from this recipe."
        },
        "project_root": {
          "type": ["string", "null"],
          "description": "Path to the detected project root directory."
        }
      },
      "required": ["command", "file", "name", "kind"]
    },
    "get_invocation_plan_request": {
      "type": "object",
      "properties": {
        "command": { "const": "get_invocation_plan" },
        "invocation_requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/invocation_requirement" },
          "description": "Targets and constraints for which the frontend should produce invocation plans."
        }
      },
      "required": ["command", "invocation_requirements"]
    },
    "shutdown_request": {
      "type": "object",
      "properties": {
        "command": { "const": "shutdown" }
      },
      "required": ["command"]
    },
    "execution_profile": {
      "type": "object",
      "properties": {
        "adapters": {
          "type": "array",
          "items": { "$ref": "#/$defs/execution_adapter" },
          "description": "Ordered opaque adapter descriptors."
        }
      },
      "required": ["adapters"]
    },
    "value_requirement": {
      "type": "object",
      "properties": {
        "param_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based parameter index."
        },
        "param_name": {
          "type": "string",
          "description": "Declared parameter name, or empty for unnamed parameters."
        },
        "type_name": {
          "type": "string",
          "description": "Language-specific type string."
        },
        "kind": {
          "type": "string",
          "enum": ["any", "non_zero", "positive", "specific"],
          "description": "Value constraint classification."
        },
        "literal": {
          "description": "Required literal value when kind is specific."
        }
      },
      "required": ["param_index", "param_name", "type_name", "kind"]
    },
    "runtime_requirement": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["receiver_construction", "package_initialization"],
          "description": "Runtime setup requirement classification."
        },
        "type_name": {
          "type": "string",
          "description": "Type involved in the requirement."
        },
        "detail": {
          "type": "string",
          "description": "Human-readable explanation of the requirement."
        }
      },
      "required": ["kind"]
    },
    "invocation_requirement": {
      "type": "object",
      "properties": {
        "target_id": {
          "type": "string",
          "description": "Stable target identifier."
        },
        "value_requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/value_requirement" },
          "description": "Per-parameter value constraints in declaration order."
        },
        "runtime_requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtime_requirement" },
          "description": "Runtime setup preconditions for invocation."
        }
      },
      "required": ["target_id", "value_requirements"]
    },
    "value_plan": {
      "type": "object",
      "properties": {
        "param_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based argument position."
        },
        "param_name": {
          "type": "string",
          "description": "Declared parameter name, or empty for unnamed parameters."
        },
        "kind": {
          "type": "string",
          "enum": ["literal", "zero", "random", "symbolic"],
          "description": "Argument production strategy."
        },
        "literal": {
          "description": "Concrete value when kind is literal."
        },
        "type_hint": {
          "type": "string",
          "description": "Language-specific type hint for code generation."
        }
      },
      "required": ["param_index", "param_name", "kind"]
    },
    "invocation_plan": {
      "type": "object",
      "properties": {
        "target_id": {
          "type": "string",
          "description": "Stable target identifier."
        },
        "receiver_kind": {
          "type": "string",
          "description": "Receiver construction strategy."
        },
        "generic_type_args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ordered concrete type argument list for generic targets."
        },
        "argument_plans": {
          "type": "array",
          "items": { "$ref": "#/$defs/value_plan" },
          "description": "One value plan per parameter, in declaration order."
        },
        "priority": {
          "type": "integer",
          "description": "Relative ordering within a plan set."
        },
        "label": {
          "type": "string",
          "description": "Optional human-readable name for this plan."
        }
      },
      "required": ["target_id", "receiver_kind", "argument_plans", "priority"]
    },
    "execution_adapter": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Namespaced adapter identifier, for example ts/react-hooks."
        },
        "apply": {
          "type": "string",
          "enum": ["required", "auto", "suggest", "disabled"],
          "description": "Application policy for this adapter."
        },
        "options": {
          "description": "Opaque adapter-local options payload."
        }
      },
      "required": ["id"]
    }
  }
}
