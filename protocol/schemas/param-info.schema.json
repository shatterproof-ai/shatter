{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shatter.dev/protocol/param-info.schema.json",
  "title": "ParamInfo",
  "description": "Metadata about a function parameter.",
  "type": "object",
  "required": ["name", "type"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Parameter name."
    },
    "type": {
      "$ref": "type-info.schema.json",
      "description": "Parameter type."
    }
  }
}
