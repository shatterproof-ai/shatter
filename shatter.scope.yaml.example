# Shatter scope configuration
#
# Controls which files to analyze and how to handle dependencies.
# Copy to shatter.scope.yaml and customize for your project.
#
# Usage: shatter explore --scope shatter.scope.yaml src/app.ts:main

scope:
  # Glob patterns for files to analyze
  include:
    - "src/**/*.ts"
    - "lib/**/*.ts"

  # Glob patterns for files to skip
  exclude:
    - "**/*.test.ts"
    - "**/*.spec.ts"
    - "dist/**"

  # Glob patterns for dependencies to replace with mocks
  mock:
    - "node_modules/**"

  # Glob patterns for dependencies to leave as real calls (overrides mock)
  passthrough:
    - "node_modules/lodash"
    - "node_modules/lodash/**"
